---
import { tools } from "../data/tools";
---

<footer class="tool-footer">
  <div class="tool-footer-inner">
    <h3 class="tool-footer-title" data-i18n="more_tools">更多工具</h3>
    <div class="tool-footer-grid">
      {
        tools.map((tool) => (
          <a href={tool.href} class="tool-footer-link">
            <span class="tool-footer-icon">{tool.icon || "🧰"}</span>
            <span class="tool-footer-label" data-i18n={tool.titleKey}>Tool</span>
          </a>
        ))
      }
    </div>

    <div class="tool-footer-legal">
      <a href="https://invsi.notion.site/User-Agreement-ada0d998b6604a58a2bd5a8d32f45066?pvs=4" data-i18n="user_agreement">User Agreement</a>
      <span>|</span>
      <a href="https://invsi.notion.site/f6522ae9d0c7415cad8f9902b983dc17?pvs=4" data-i18n="privacy_policy">Privacy Policy</a>
      <span>|</span>
      <a href="https://invsi.notion.site/fb88822450e049d9a116d5b37c651883?pvs=4" data-i18n="terms_of_use">Terms of Use</a>
    </div>

    <div class="tool-footer-meta">
      <div>Copyright © 2026 DoCool. All rights reserved.</div>
      <div class="tool-footer-meta-links">
        <a href="https://www.xiaohongshu.com/user/profile/5777e1583460946ad6894dc4" target="_blank" rel="noopener noreferrer" data-i18n="footer_xhs">Xiaohongshu</a>
        <a href="mailto:deepseals@icloud.com" data-i18n="footer_contact">Contact Us</a>
      </div>
    </div>
  </div>
</footer>
