---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainFooter from "../components/MainFooter.astro";
import MainNav from "../components/MainNav.astro";
---

<BaseLayout
  title="NexPaste - 为 macOS 打造的高性能剪贴板管家"
  description="NexPaste 是专为 macOS 打造的高级剪贴板管理器，支持文本、图片、文件历史、快速搜索、迷你面板、标签和本地隐私保护。"
  canonical="https://maxc.cc/nexpaste/"
  ogImage="https://maxc.cc/images/nexpaste-icon.png"
  includeHomeStyles={true}
  includeHomeScript={true}
>
  <MainNav showSectionLinks={false} />

  <div class="nexpaste-landing-page">
      <main id="top">
        <header class="hero">
          <div class="hero-content">
            <img class="app-icon" src="/images/nexpaste-icon.png" alt="NexPaste 应用图标">
            <h1 class="reveal" data-i18n="np_landing_hero_title">复制过的，瞬间回来。</h1>
            <p class="hero-copy reveal" data-i18n="np_landing_hero_copy">为 macOS 打造的原生剪贴板管家。轻轻一搜，马上可用。</p>
            <div class="cta-row reveal">
              <a class="primary-link" href="https://apps.apple.com/app/id6761368515" data-i18n="np_landing_app_store">App Store</a>
            </div>

            <div class="hero-stage reveal" aria-label="NexPaste 界面预览">
              <div class="mac-window">
                <div class="real-panel">
                  <div class="real-controls">
                    <button class="real-search" type="button" aria-label="搜索">⌕</button>
                    <div class="real-chips" aria-label="类型和标签筛选">
                  <span class="real-chip active" data-i18n="np_landing_chip_all">全部</span>
                  <span class="real-chip cyan" data-i18n="np_landing_chip_text">文本</span>
                  <span class="real-chip green" data-i18n="np_landing_chip_images">图片</span>
                  <span class="real-chip orange" data-i18n="np_landing_chip_files">文件</span>
                  <span class="real-chip pink" data-i18n="np_landing_chip_favorites">已收藏</span>
                  <span class="real-chip purple" data-i18n="np_landing_tag_work"># 工作</span>
                  <span class="real-chip teal" data-i18n="np_landing_tag_common"># 常用</span>
                  <span class="real-chip neutral">＋</span>
                    </div>
                  </div>
                  <div class="horizontal-shell">
                    <div class="horizontal-track">
                      <article class="real-card selected">
                        <span class="quick-badge">⌘1</span>
                        <div class="card-head">
                          <div class="source"><span class="app-dot"></span><span>Safari</span></div>
                          <span class="time" data-i18n="np_landing_time_now">刚刚</span>
                        </div>
                        <h2 class="real-title" data-i18n="np_landing_card_title">NexPaste 产品介绍页文案</h2>
                        <p class="real-text" data-i18n="np_landing_card_desc">复制过的段落、代码、邮箱、回复模板，都会按时间排好。单击复制，回车使用。</p>
                        <div class="real-tags"><span class="real-tag" data-i18n="np_landing_tag_work"># 工作</span><span class="real-tag" data-i18n="np_landing_tag_copy"># 文案</span></div>
                      </article>
                      <article class="real-card image" aria-label="图片剪贴板卡片">
                      </article>
                      <article class="real-card">
                        <div class="card-head">
                          <div class="source"><span class="app-dot green"></span><span>Messages</span></div>
                          <span class="time" data-i18n="np_landing_time_2m">2 分钟前</span>
                        </div>
                        <h2 class="real-title" data-i18n="np_landing_code_title">验证码 482917</h2>
                        <p class="real-text" data-i18n="np_landing_code_desc">短文本、链接和账号信息，也能快速找回。</p>
                      </article>
                      <article class="real-card">
                        <div class="card-head">
                          <div class="source"><span class="app-dot pink"></span><span>Xcode</span></div>
                          <span class="time" data-i18n="np_landing_time_8m">8 分钟前</span>
                        </div>
                        <h2 class="real-title">ClipboardStore.swift</h2>
                        <p class="real-text">let sourceItems = filteredItems<br>viewModel.selectedHistoryItemID = item.id</p>
                        <div class="real-tags"><span class="real-tag" data-i18n="np_landing_tag_code"># 代码</span></div>
                      </article>
                      <article class="real-card">
                        <div class="card-head">
                          <div class="source"><span class="app-dot orange"></span><span>Finder</span></div>
                          <span class="time" data-i18n="np_landing_time_12m">12 分钟前</span>
                        </div>
                        <h2 class="real-title">Presentation.key</h2>
                        <p class="real-text" data-i18n="np_landing_file_desc">文件引用也会保留，随时重新复制。</p>
                      </article>
                      <article class="real-card selected" aria-hidden="true">
                        <span class="quick-badge">⌘1</span>
                        <div class="card-head">
                          <div class="source"><span class="app-dot"></span><span>Safari</span></div>
                          <span class="time" data-i18n="np_landing_time_now">刚刚</span>
                        </div>
                        <h2 class="real-title" data-i18n="np_landing_card_title">NexPaste 产品介绍页文案</h2>
                        <p class="real-text" data-i18n="np_landing_card_desc">复制过的段落、代码、邮箱、回复模板，都会按时间排好。单击复制，回车使用。</p>
                        <div class="real-tags"><span class="real-tag" data-i18n="np_landing_tag_work"># 工作</span><span class="real-tag" data-i18n="np_landing_tag_copy"># 文案</span></div>
                      </article>
                      <article class="real-card image" aria-hidden="true"></article>
                      <article class="real-card" aria-hidden="true">
                        <div class="card-head">
                          <div class="source"><span class="app-dot green"></span><span>Messages</span></div>
                          <span class="time" data-i18n="np_landing_time_2m">2 分钟前</span>
                        </div>
                        <h2 class="real-title" data-i18n="np_landing_code_title">验证码 482917</h2>
                        <p class="real-text" data-i18n="np_landing_code_desc">短文本、链接和账号信息，也能快速找回。</p>
                      </article>
                      <article class="real-card" aria-hidden="true">
                        <div class="card-head">
                          <div class="source"><span class="app-dot pink"></span><span>Xcode</span></div>
                          <span class="time" data-i18n="np_landing_time_8m">8 分钟前</span>
                        </div>
                        <h2 class="real-title">ClipboardStore.swift</h2>
                        <p class="real-text">let sourceItems = filteredItems<br>viewModel.selectedHistoryItemID = item.id</p>
                        <div class="real-tags"><span class="real-tag" data-i18n="np_landing_tag_code"># 代码</span></div>
                      </article>
                      <article class="real-card" aria-hidden="true">
                        <div class="card-head">
                          <div class="source"><span class="app-dot orange"></span><span>Finder</span></div>
                          <span class="time" data-i18n="np_landing_time_12m">12 分钟前</span>
                        </div>
                        <h2 class="real-title">Presentation.key</h2>
                        <p class="real-text" data-i18n="np_landing_file_desc">文件引用也会保留，随时重新复制。</p>
                      </article>
                    </div>
                    <div class="scroll-hint" aria-hidden="true"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </header>

        <section id="workflow">
          <div class="section-inner">
            <p class="section-kicker reveal" data-i18n="np_landing_workflow_kicker">毫秒级呼出</p>
            <h2 class="section-title reveal" data-i18n="np_landing_workflow_title">需要时出现。用完就退场。</h2>
            <p class="section-lead reveal" data-i18n="np_landing_workflow_lead">快捷键呼出，左右滑动浏览，回车使用。</p>

            <div class="feature-band split reveal">
              <div class="split-text">
                <h3 data-i18n="np_landing_keyboard_title">键盘优先。</h3>
                <p data-i18n="np_landing_keyboard_desc">搜索、筛选、选择，都在同一个轻量面板里完成。</p>
              </div>
              <div class="command-visual" aria-label="快捷键视觉">
                <div class="key-stack">
                  <div class="key">⇧</div>
                  <div class="key">⌘</div>
                  <div class="key key-space">Space</div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section id="features">
          <div class="section-inner">
            <p class="section-kicker reveal" data-i18n="np_landing_features_kicker">更聪明的历史</p>
            <h2 class="section-title reveal" data-i18n="np_landing_features_title">把剪贴板变成可复用的内容库。</h2>
            <div class="tile-grid">
              <article class="tile reveal">
                <h3 data-i18n="np_landing_auto_title">自动分类。</h3>
                <p data-i18n="np_landing_auto_desc">文本、图片、文件和链接，清晰呈现。</p>
                <div class="tile-visual">
                  <div class="tag-cloud">
                    <span class="tag" data-i18n="np_landing_chip_text">文本</span>
                    <span class="tag" data-i18n="np_landing_chip_images">图片</span>
                    <span class="tag" data-i18n="np_landing_chip_files">文件</span>
                    <span class="tag" data-i18n="np_landing_chip_links">链接</span>
                    <span class="tag" data-i18n="np_landing_tag_favorite">收藏</span>
                  </div>
                </div>
              </article>
              <article class="tile reveal">
                <h3 data-i18n="np_landing_pinned_title">常用常驻。</h3>
                <p data-i18n="np_landing_pinned_desc">账号、模板、命令和素材，用标签收好。</p>
                <div class="tile-visual">
                  <div class="tag-cloud">
                    <span class="tag" data-i18n="np_landing_tag_account">账号</span>
                    <span class="tag" data-i18n="np_landing_tag_company">公司</span>
                    <span class="tag" data-i18n="np_landing_tag_common_plain">常用</span>
                    <span class="tag" data-i18n="np_landing_tag_code_plain">代码</span>
                    <span class="tag" data-i18n="np_landing_tag_client">客户</span>
                  </div>
                </div>
              </article>
              <article class="tile reveal">
                <h3 data-i18n="np_landing_mini_title">迷你面板。</h3>
                <p data-i18n="np_landing_mini_desc">更轻、更近，适合高频操作。</p>
                <div class="tile-visual">
                  <div class="sync-orbit">
                    <div class="sync-center">⌘</div>
                  </div>
                </div>
              </article>
            </div>
          </div>
        </section>

        <section id="privacy">
          <div class="section-inner">
            <p class="section-kicker reveal" data-i18n="np_landing_privacy_kicker">隐私优先</p>
            <h2 class="section-title reveal" data-i18n="np_landing_privacy_title">你的历史，留在你的 Mac。</h2>
            <p class="section-lead reveal" data-i18n="np_landing_privacy_lead">本地保存。可暂停记录，也可过滤指定应用。</p>

            <div class="feature-band split reveal">
              <div class="command-visual">
                <div class="privacy-vault" aria-hidden="true">
                  <div class="privacy-dots"><span></span><span></span><span></span></div>
                  <div class="privacy-shield"></div>
                  <div class="privacy-lines">
                    <span class="privacy-line"></span>
                    <span class="privacy-line"></span>
                  </div>
                </div>
              </div>
              <div class="split-text">
                <h3 data-i18n="np_landing_privacy_card_title">记录什么，由你决定。</h3>
                <p data-i18n="np_landing_privacy_card_desc">敏感 App 可过滤。历史也能随时清空。</p>
              </div>
            </div>
          </div>
        </section>

        <section class="pro" aria-label="高级能力">
          <div class="section-inner">
            <p class="section-kicker reveal" data-i18n="np_landing_pro_kicker">为长期使用打磨</p>
            <h2 class="section-title reveal" data-i18n="np_landing_pro_title">轻巧。原生。足够强大。</h2>
            <p class="section-lead reveal" data-i18n="np_landing_pro_lead">SwiftUI、系统材质、快捷键和同步能力，一应俱全。</p>
            <div class="pro-card">
              <div class="pro-item reveal">
                <strong data-i18n="np_landing_sync_title">iCloud 同步</strong>
                <span data-i18n="np_landing_sync_desc">文本、图片、文件，按需同步。</span>
              </div>
              <div class="pro-item reveal">
                <strong data-i18n="np_landing_settings_title">精细设置</strong>
                <span data-i18n="np_landing_settings_desc">面板、语言、快捷键，都能调整。</span>
              </div>
              <div class="pro-item reveal">
                <strong data-i18n="np_landing_native_title">原生体验</strong>
                <span data-i18n="np_landing_native_desc">系统材质、状态栏菜单和标准 macOS 交互。</span>
              </div>
              <div class="pro-item reveal">
                <strong data-i18n="np_landing_perf_title">高性能预览</strong>
                <span data-i18n="np_landing_perf_desc">快速响应，后台轻量。</span>
              </div>
            </div>
          </div>
        </section>

        <section id="download" class="final">
          <div class="section-inner reveal">
            <img class="app-icon" src="/images/nexpaste-icon.png" alt="NexPaste 应用图标">
            <h2 data-i18n="np_landing_final_title">NexPaste<br>让复制粘贴重新变快。</h2>
            <p data-i18n="np_landing_final_desc">简洁、私密、随叫随到。</p>
            <div class="cta-row">
              <a class="primary-link" href="https://apps.apple.com/app/id6761368515" data-i18n="np_landing_go_app_store">前往 App Store</a>
              <a class="secondary-link" href="#top" data-i18n="np_landing_back_top">回到顶部</a>
            </div>
          </div>
        </section>
      </main>
  </div>

  <MainFooter />

  <style>
    .nexpaste-landing-page {
          color-scheme: light;
          --bg: #f5f5f7;
          --surface: rgba(255, 255, 255, 0.78);
          --surface-strong: rgba(255, 255, 255, 0.92);
          --ink: #1d1d1f;
          --muted: #6e6e73;
          --hairline: rgba(0, 0, 0, 0.08);
          --blue: #0071e3;
          --cyan: #00a5d8;
          --green: #2fd068;
          --orange: #ff9f0a;
          --pink: #ff375f;
          --shadow: 0 28px 80px rgba(0, 0, 0, 0.16);
          --soft-shadow: 0 18px 60px rgba(0, 0, 0, 0.11);
          --radius: 28px;
        }

        * {
          box-sizing: border-box;
        }

    :global(html) {
      scroll-behavior: smooth;
      background: #f5f5f7;
    }

    :global(body) {
      margin: 0;
    }

        .nexpaste-landing-page {
          margin: 0;
          font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
          color: var(--ink);
          background:
            radial-gradient(circle at 50% -4%, rgba(0, 113, 227, 0.10), transparent 30rem),
            linear-gradient(180deg, #fff 0%, var(--bg) 24rem);
          letter-spacing: 0;
          overflow-x: hidden;
        }

        a {
          color: inherit;
          text-decoration: none;
        }

        img {
          display: block;
          max-width: 100%;
        }

        .hero {
          position: relative;
          display: grid;
          align-items: end;
          min-height: 94vh;
          padding: 116px 22px 34px;
          isolation: isolate;
        }

        .hero-content {
          width: min(1280px, 100%);
          margin: 0 auto;
          text-align: center;
        }

        .app-icon {
          width: 88px;
          height: 88px;
          margin: 0 auto 22px;
          border-radius: 22px;
          box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
          animation: floatIcon 5s ease-in-out infinite;
        }

        .eyebrow {
          margin: 0 0 12px;
          color: var(--blue);
          font-size: 18px;
          font-weight: 700;
          line-height: 1.2;
        }

        h1 {
          max-width: 860px;
          margin: 0 auto;
          font-size: clamp(40px, 6vw, 76px);
          font-weight: 700;
          line-height: 1.02;
          letter-spacing: 0;
        }

        .hero-copy {
          max-width: 640px;
          margin: 18px auto 0;
          color: var(--muted);
          font-size: clamp(17px, 1.8vw, 22px);
          font-weight: 500;
          line-height: 1.28;
        }

        .cta-row {
          display: flex;
          justify-content: center;
          gap: 18px;
          margin: 26px 0 36px;
          font-size: 17px;
          font-weight: 500;
        }

        .primary-link,
        .secondary-link {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          min-height: 44px;
          padding: 0 24px;
          border-radius: 999px;
          transition: transform 180ms ease, background 180ms ease;
        }

        .primary-link {
          color: #fff;
          background: var(--blue);
        }

        .secondary-link {
          color: var(--blue);
          background: rgba(0, 113, 227, 0.10);
        }

        .primary-link:hover,
        .secondary-link:hover {
          transform: translateY(-1px);
        }

        .hero-stage {
          position: relative;
          width: min(1240px, 100%);
          margin: 0 auto;
          min-height: 360px;
          perspective: 1600px;
        }

        .mac-window {
          position: relative;
          overflow: hidden;
          width: min(1120px, calc(100vw - 34px));
          margin: 0 auto;
          border: 1px solid rgba(0, 0, 0, 0.12);
          border-radius: 24px;
          background: rgba(250, 250, 252, 0.78);
          box-shadow: var(--shadow);
          backdrop-filter: blur(28px) saturate(160%);
          -webkit-backdrop-filter: blur(28px) saturate(160%);
          transform: rotateX(3deg);
        }

        .real-panel {
          padding: 14px;
          min-height: 330px;
        }

        .real-controls {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 12px;
          margin-bottom: 14px;
        }

        .real-search {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          width: 36px;
          height: 36px;
          border: 1px solid rgba(0, 0, 0, 0.08);
          border-radius: 11px;
          background: rgba(255, 255, 255, 0.74);
          color: var(--muted);
          font-size: 20px;
          font-weight: 700;
          box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
          flex: 0 0 auto;
          appearance: none;
          -webkit-appearance: none;
          cursor: default;
        }

        .real-chips {
          display: flex;
          flex-wrap: wrap;
          justify-content: center;
          gap: 8px;
          flex: 0 1 auto;
        }

        .real-chip {
          --chip-bg: rgba(110, 110, 115, 0.13);
          --chip-fg: #2c2c2e;
          display: inline-flex;
          align-items: center;
          gap: 6px;
          min-height: 32px;
          padding: 0 11px;
          border-radius: 999px;
          background: var(--chip-bg);
          color: var(--chip-fg);
          font-size: 12px;
          font-weight: 650;
          white-space: nowrap;
          box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.32);
        }

        .real-chip.active {
          --chip-bg: var(--blue);
          --chip-fg: #fff;
        }

        .real-chip.cyan {
          --chip-bg: #d7f4ff;
          --chip-fg: #005f78;
        }

        .real-chip.green {
          --chip-bg: #d9f8e1;
          --chip-fg: #07501f;
        }

        .real-chip.orange {
          --chip-bg: #ffe3b3;
          --chip-fg: #6d4100;
        }

        .real-chip.pink {
          --chip-bg: #ffdbe4;
          --chip-fg: #9c0b2f;
        }

        .real-chip.purple {
          --chip-bg: #e9ddff;
          --chip-fg: #4d31b8;
        }

        .real-chip.teal {
          --chip-bg: #d6f7f1;
          --chip-fg: #00685c;
        }

        .real-chip.neutral {
          --chip-bg: rgba(60, 60, 67, 0.12);
          --chip-fg: #3a3a3c;
        }

        .horizontal-shell {
          position: relative;
          overflow: hidden;
          min-height: 258px;
          border-radius: 20px;
        }

        .horizontal-track {
          display: flex;
          align-items: flex-start;
          gap: 12px;
          width: max-content;
          padding: 2px 12px 22px 0;
          transform: translateX(0);
          animation: marqueeScroll 22s linear infinite;
        }

        .horizontal-shell::after {
          content: "";
          position: absolute;
          top: 0;
          right: 0;
          bottom: 0;
          width: 82px;
          pointer-events: none;
          background: linear-gradient(90deg, rgba(250, 250, 252, 0), rgba(250, 250, 252, 0.94));
        }

        .scroll-hint {
          position: absolute;
          left: 50%;
          bottom: 2px;
          width: 112px;
          height: 4px;
          border-radius: 999px;
          background: rgba(60, 60, 67, 0.14);
          transform: translateX(-50%);
          overflow: hidden;
        }

        .scroll-hint::after {
          content: "";
          display: block;
          width: 42px;
          height: 100%;
          border-radius: inherit;
          background: rgba(60, 60, 67, 0.34);
          animation: scrollThumb 22s linear infinite;
        }

        .real-card {
          position: relative;
          flex: 0 0 240px;
          overflow: hidden;
          width: 240px;
          height: 240px;
          border: 1px solid rgba(0, 0, 0, 0.08);
          border-radius: 18px;
          background: rgba(255, 255, 255, 0.86);
          box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
          padding: 11px;
          transition: transform 220ms ease, box-shadow 220ms ease;
        }

        .real-card:hover {
          transform: translateY(-2px);
          box-shadow: 0 14px 34px rgba(0, 0, 0, 0.10);
        }

        .real-card.selected {
          box-shadow: 0 0 0 2px rgba(0, 113, 227, 0.86), 0 14px 34px rgba(0, 0, 0, 0.10);
        }

        .real-card.image {
          height: 240px;
          padding: 0;
          background: linear-gradient(135deg, #dff3ff 0%, #92c6ff 45%, #f8d6e5 100%);
        }

        .real-card.image::before {
          content: "";
          position: absolute;
          left: 24px;
          right: 24px;
          bottom: 28px;
          height: 96px;
          border-radius: 18px;
          background:
            radial-gradient(circle at 76% 22%, #fff 0 16px, transparent 17px),
            linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.20));
          box-shadow: 0 18px 44px rgba(57, 94, 144, 0.20);
        }

        .card-head {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 12px;
          margin-bottom: 8px;
        }

        .source {
          display: flex;
          align-items: center;
          gap: 7px;
          min-width: 0;
          color: var(--muted);
          font-size: 11px;
          font-weight: 650;
        }

        .app-dot {
          width: 16px;
          height: 16px;
          border-radius: 4px;
          background: linear-gradient(135deg, var(--blue), var(--cyan));
          box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.50);
          flex: 0 0 auto;
        }

        .app-dot.green { background: linear-gradient(135deg, #34c759, #8fdc52); }
        .app-dot.orange { background: linear-gradient(135deg, #ff9f0a, #ffd60a); }
        .app-dot.pink { background: linear-gradient(135deg, #ff375f, #ff9fba); }

        .time {
          color: #9a9aa0;
          font-size: 11px;
          font-weight: 600;
          white-space: nowrap;
        }

        .real-title {
          margin: 0 0 6px;
          font-size: 16px;
          font-weight: 700;
          line-height: 1.22;
        }

        .real-text {
          margin: 0;
          color: var(--muted);
          font-size: 12px;
          line-height: 1.34;
          display: -webkit-box;
          -webkit-line-clamp: 7;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }

        .real-tags {
          display: flex;
          flex-wrap: wrap;
          gap: 5px;
          margin-top: 10px;
        }

        .real-tag {
          padding: 3px 7px;
          border-radius: 999px;
          background: rgba(0, 113, 227, 0.10);
          color: var(--blue);
          font-size: 10px;
          font-weight: 700;
        }

        .quick-badge {
          position: absolute;
          top: 10px;
          right: 10px;
          min-width: 34px;
          min-height: 24px;
          padding: 4px 7px;
          border-radius: 999px;
          color: #fff;
          background: rgba(0, 113, 227, 0.92);
          font-size: 11px;
          font-weight: 800;
          text-align: center;
        }

        section {
          padding: 88px 22px;
        }

        .section-inner {
          max-width: 1120px;
          margin: 0 auto;
        }

        .section-kicker {
          margin: 0 0 10px;
          color: var(--blue);
          font-size: 18px;
          font-weight: 700;
          line-height: 1.2;
        }

        .section-title {
          max-width: 900px;
          margin: 0;
          font-size: clamp(30px, 4.5vw, 52px);
          font-weight: 700;
          line-height: 1.04;
        }

        .section-lead {
          max-width: 760px;
          margin: 22px 0 0;
          color: var(--muted);
          font-size: clamp(17px, 2vw, 22px);
          font-weight: 500;
          line-height: 1.3;
        }

        .feature-band {
          margin-top: 52px;
          border-radius: var(--radius);
          background: #fff;
          overflow: hidden;
          box-shadow: 0 1px 0 var(--hairline);
        }

        .split {
          display: grid;
          grid-template-columns: 0.95fr 1.05fr;
          min-height: 560px;
        }

        .split-text {
          display: grid;
          align-content: center;
          padding: clamp(32px, 5vw, 64px);
        }

        .split-text h3,
        .tile h3 {
          margin: 0;
          font-size: clamp(26px, 3vw, 38px);
          font-weight: 700;
          line-height: 1.06;
        }

        .split-text p,
        .tile p {
          margin: 18px 0 0;
          color: var(--muted);
          font-size: 18px;
          font-weight: 500;
          line-height: 1.38;
        }

        .command-visual {
          position: relative;
          display: grid;
          place-items: center;
          min-height: 560px;
          background:
            linear-gradient(135deg, rgba(0, 113, 227, 0.13), rgba(47, 208, 104, 0.10)),
            var(--bg);
        }

        .key-stack {
          display: flex;
          gap: 14px;
          transform: rotate(-8deg);
        }

        .key {
          display: grid;
          place-items: center;
          width: clamp(74px, 10vw, 118px);
          height: clamp(74px, 10vw, 118px);
          border: 1px solid var(--hairline);
          border-radius: 24px;
          background: rgba(255, 255, 255, 0.78);
          box-shadow: 0 18px 48px rgba(0, 0, 0, 0.12);
          font-size: clamp(24px, 4vw, 42px);
          font-weight: 700;
          animation: keyPress 4.8s ease-in-out infinite;
        }

        .key:nth-child(2) { animation-delay: 0.16s; }
        .key:nth-child(3) { animation-delay: 0.32s; }

        .key-space {
          padding-inline: 8px;
          font-size: clamp(15px, 2.2vw, 24px);
          line-height: 1;
          overflow: hidden;
        }

        .tile-grid {
          display: grid;
          grid-template-columns: repeat(3, minmax(0, 1fr));
          gap: 18px;
          margin-top: 52px;
        }

        .tile {
          min-height: 430px;
          overflow: hidden;
          border-radius: var(--radius);
          background: #fff;
          padding: 34px;
          box-shadow: 0 1px 0 var(--hairline);
        }

        .tile h3 {
          font-size: clamp(23px, 2.4vw, 30px);
        }

        .tile p {
          font-size: 16px;
        }

        .tile-visual {
          position: relative;
          height: 190px;
          margin: 30px -12px -8px;
        }

        .privacy-vault {
          position: relative;
          width: min(420px, calc(100% - 48px));
          min-height: 300px;
          border: 1px solid rgba(0, 0, 0, 0.08);
          border-radius: 30px;
          background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.62)),
            radial-gradient(circle at 50% 0%, rgba(0, 113, 227, 0.14), transparent 62%);
          box-shadow: 0 24px 70px rgba(0, 0, 0, 0.12);
          overflow: hidden;
        }

        .privacy-vault::before {
          content: "";
          position: absolute;
          inset: 0 0 auto;
          height: 48px;
          border-bottom: 1px solid rgba(0, 0, 0, 0.06);
          background: rgba(255, 255, 255, 0.56);
        }

        .privacy-dots {
          position: absolute;
          top: 20px;
          left: 22px;
          display: flex;
          gap: 7px;
        }

        .privacy-dots span {
          width: 9px;
          height: 9px;
          border-radius: 50%;
          background: rgba(60, 60, 67, 0.22);
        }

        .privacy-shield {
          position: absolute;
          top: 78px;
          left: 50%;
          width: 112px;
          height: 128px;
          transform: translateX(-50%);
          border-radius: 34px 34px 42px 42px;
          background: linear-gradient(180deg, #34c759, #0a84ff);
          box-shadow: 0 18px 42px rgba(0, 113, 227, 0.26);
          clip-path: polygon(50% 0, 92% 16%, 86% 76%, 50% 100%, 14% 76%, 8% 16%);
        }

        .privacy-shield::before {
          content: "";
          position: absolute;
          inset: 12px;
          background: rgba(255, 255, 255, 0.20);
          clip-path: inherit;
        }

        .privacy-shield::after {
          content: "";
          position: absolute;
          left: 37px;
          top: 46px;
          width: 38px;
          height: 22px;
          border-left: 8px solid rgba(255, 255, 255, 0.94);
          border-bottom: 8px solid rgba(255, 255, 255, 0.94);
          border-radius: 0 0 0 6px;
          transform: rotate(-45deg);
        }

        .privacy-lines {
          position: absolute;
          left: 32px;
          right: 32px;
          bottom: 28px;
          display: grid;
          gap: 10px;
        }

        .privacy-line {
          height: 14px;
          border-radius: 999px;
          background: rgba(60, 60, 67, 0.10);
        }

        .privacy-line:nth-child(1) { width: 76%; }
        .privacy-line:nth-child(2) { width: 58%; }

        .tag-cloud {
          display: flex;
          flex-wrap: wrap;
          align-content: center;
          justify-content: center;
          gap: 10px;
          height: 100%;
        }

        .tag {
          padding: 8px 13px;
          border-radius: 999px;
          background: rgba(0, 113, 227, 0.11);
          color: var(--blue);
          font-size: 12px;
          font-weight: 700;
        }

        .sync-orbit {
          position: absolute;
          inset: 8px 22px;
          display: grid;
          place-items: center;
        }

        .sync-orbit::before,
        .sync-orbit::after {
          content: "";
          position: absolute;
          border: 1px solid var(--hairline);
          border-radius: 50%;
        }

        .sync-orbit::before {
          width: 190px;
          height: 112px;
          transform: rotate(18deg);
        }

        .sync-orbit::after {
          width: 190px;
          height: 112px;
          transform: rotate(-18deg);
        }

        .sync-center {
          display: grid;
          place-items: center;
          width: 84px;
          height: 84px;
          border-radius: 22px;
          background: var(--surface-strong);
          box-shadow: 0 12px 34px rgba(0, 0, 0, 0.12);
          font-size: 30px;
        }

        .pro {
          background:
            radial-gradient(circle at 50% 0%, rgba(255, 159, 10, 0.12), transparent 28rem),
            var(--bg);
          color: var(--ink);
        }

        .pro .section-kicker {
          color: var(--orange);
        }

        .pro .section-lead {
          color: var(--muted);
        }

        .pro-card {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 18px;
          margin-top: 52px;
        }

        .pro-item {
          min-height: 220px;
          border: 1px solid rgba(0, 0, 0, 0.08);
          border-radius: var(--radius);
          background: rgba(255, 255, 255, 0.82);
          padding: 34px;
          backdrop-filter: blur(18px);
          -webkit-backdrop-filter: blur(18px);
        }

        .pro-item strong {
          display: block;
          font-size: 22px;
          line-height: 1.16;
        }

        .pro-item span {
          display: block;
          margin-top: 12px;
          color: var(--muted);
          font-size: 16px;
          line-height: 1.4;
        }

        .final {
          min-height: 74vh;
          display: grid;
          place-items: center;
          text-align: center;
          padding-bottom: 110px;
        }

        .final h2 {
          margin: 24px auto 0;
          max-width: 880px;
          font-size: clamp(34px, 5vw, 58px);
          line-height: 1;
          letter-spacing: 0;
        }

        .final p {
          max-width: 660px;
          margin: 24px auto 0;
          color: var(--muted);
          font-size: 18px;
          font-weight: 500;
          line-height: 1.33;
