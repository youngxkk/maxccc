---
import BaseLayout from "../layouts/BaseLayout.astro";
import MainNav from "../components/MainNav.astro";
import MainFooter from "../components/MainFooter.astro";
---

<BaseLayout 
  title="NexPaste - Advanced macOS Clipboard Manager" 
  description="Elevate your clipboard experience with NexPaste. A premium, high-performance clipboard manager for power users on macOS."
  includeHomeStyles={true}
  includeHomeScript={true}
>
  <MainNav showSectionLinks={false} />

  <main class="nexpaste-page">
    <div class="mouse-glow"></div>
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container hero-content">
        <div class="hero-text fade-up-entry">
          <h1 data-i18n="np_hero_title">Elevate Your Clipboard Experience</h1>
          <p class="subtitle" data-i18n="np_hero_subtitle">The premium productivity powerhouse for macOS. Fast, secure, and native.</p>
          <div class="cta-group">
            <a href="#" class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-download">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              <span data-i18n="np_download">Download for macOS</span>
            </a>
          </div>
        </div>
        <div class="hero-image-container fade-up-entry">
          <div class="mac-window-mockup">
            <div class="window-header">
              <div class="dots">
                <span class="dot red"></span>
                <span class="dot yellow"></span>
                <span class="dot green"></span>
              </div>
            </div>
            <img src="/images/nexpaste-hero.png" alt="NexPaste macOS Application Mockup" class="hero-image" />
          </div>
          <div class="hero-blur-bg"></div>
        </div>
      </div>
    </section>

    <!-- Feature Grid Section -->
    <section class="features-section">
      <div class="container">
        <div class="section-badge fade-up-entry">Features</div>
        <div class="feature-grid">
          <div class="feature-card card fade-up-entry">
            <div class="feature-icon">📦</div>
            <h3 data-i18n="np_feature_clipboard_title">Smart History</h3>
            <p data-i18n="np_feature_clipboard_desc">Automatically capture and categorize text, high-res images, and files for instant access.</p>
          </div>
          <div class="feature-card card fade-up-entry">
            <div class="feature-icon">🔄</div>
            <h3 data-i18n="np_feature_autopaste_title">Magic Auto-Paste</h3>
            <p data-i18n="np_feature_autopaste_desc">Seamlessly summon and paste into your active app with the power of Accessibility API.</p>
          </div>
          <div class="feature-card card fade-up-entry">
            <div class="feature-icon">⚡️</div>
            <h3 data-i18n="np_feature_speed_title">Hyper-Fast Efficiency</h3>
            <p data-i18n="np_feature_speed_desc">Millisecond-level search, full keyboard navigation, and customizable global hotkeys.</p>
          </div>
          <div class="feature-card card fade-up-entry">
            <div class="feature-icon">🌐</div>
            <h3 data-i18n="np_feature_native_title">International Native</h3>
            <p data-i18n="np_feature_native_desc">Built-in support for English, Simplified Chinese, and Traditional Chinese with a native feel.</p>
          </div>
          <div class="feature-card card fade-up-entry">
            <div class="feature-icon">🛡</div>
            <h3 data-i18n="np_feature_privacy_title">Privacy First</h3>
            <p data-i18n="np_feature_privacy_desc">100% Local storage. No data ever leaves your computer. Zero tracking.</p>
          </div>
          <div class="feature-card card fade-up-entry">
            <div class="feature-icon">🎨</div>
            <h3 data-i18n="np_feature_swift_title">Premium Interaction</h3>
            <p data-i18n="np_feature_swift_desc">Powered by Swift 6 and SwiftUI, featuring native macOS panel animations and haptic feedback.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Shortcut Section -->
    <section class="shortcut-section">
      <div class="container container-narrow">
        <div class="shortcut-info fade-up-entry">
          <h2 data-i18n="np_shortcut_title">Power at Your Fingertips</h2>
          <p data-i18n="np_shortcut_desc">A keyboard-first experience designed for power users.</p>
        </div>
        
        <div class="shortcut-viz fade-up-entry">
          <div class="viz-row">
            <div class="viz-label" data-i18n="np_shortcut_toggle">Toggle NexPaste</div>
            <div class="viz-keys">
              <kbd>⌘</kbd>
              <kbd>Shift</kbd>
              <kbd>V</kbd>
            </div>
          </div>
          <div class="viz-row">
            <div class="viz-label" data-i18n="np_shortcut_paste">Paste Item</div>
            <div class="viz-keys">
              <kbd>Enter</kbd>
            </div>
          </div>
          <div class="viz-row">
            <div class="viz-label" data-i18n="np_shortcut_search">Start Typing</div>
            <div class="viz-keys">
              <span class="typing-cursor">|</span>
              <span class="typing-text">Search clipboard...</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Section -->
    <section class="trust-section">
      <div class="container">
        <div class="trust-grid fade-up-entry">
          <div class="trust-item">
            <div class="trust-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
            </div>
            <h4 data-i18n="np_trust_title">Safe, Powerful, Transparent</h4>
            <p data-i18n="np_trust_tech">Built with Swift 6 + SwiftUI for the most modern macOS experience possible.</p>
          </div>
          <div class="trust-item">
            <div class="trust-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            </div>
            <h4 data-i18n="np_feature_privacy_title">Privacy First</h4>
            <p data-i18n="np_trust_privacy">We respect your data. No accounts, no internet, total control.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <MainFooter />

  <style>
    /* Styling for the NexPaste Landing Page */
    .nexpaste-page {
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display", "Inter", sans-serif;
      color: #1d1d1f;
      background-color: #fff;
      overflow-x: hidden;
    }

    [data-theme="dark"] .nexpaste-page {
      color: #f5f5f7;
      background-color: #000;
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 40px;
    }

    .container-narrow {
      max-width: 800px;
    }

    /* Hero Section */
    .hero-section {
      padding: 120px 0 80px;
      overflow: hidden;
      min-height: 80vh;
      display: flex;
      align-items: center;
    }

    .hero-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }

    .hero-text h1 {
      font-size: 64px;
      line-height: 1.1;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin-bottom: 24px;
      background: linear-gradient(135deg, #1d1d1f 0%, #434343 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    [data-theme="dark"] .hero-text h1 {
      background: linear-gradient(135deg, #fff 0%, #a1a1a6 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero-text .subtitle {
      font-size: 24px;
      color: #86868b;
      margin-bottom: 40px;
      line-height: 1.4;
      font-weight: 400;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      padding: 14px 28px;
      border-radius: 100px;
      font-size: 17px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s cubic-bezier(0.12, 0, 0.39, 0);
    }

    .btn-primary {
      background: #0071e3;
      color: white;
      gap: 10px;
    }

    .btn-primary:hover {
      background: #0077ed;
      transform: scale(1.02);
      box-shadow: 0 5px 15px rgba(0, 113, 227, 0.3);
    }

    .hero-image-container {
      position: relative;
    }

    .mac-window-mockup {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(30px) saturate(180%);
      border: 1px solid rgba(255, 255, 255, 0.3);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2);
      transform: perspective(1000px) rotateY(-5deg) rotateX(2deg);
      transition: transform 0.5s ease;
    }

    .mac-window-mockup:hover {
      transform: perspective(1000px) rotateY(0) rotateX(0);
    }

    .window-header {
      padding: 12px 16px;
      background: rgba(255, 255, 255, 0.1);
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      display: flex;
    }

    .dots {
      display: flex;
      gap: 8px;
    }

    .dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }

    .dot.red { background: #ff5f57; }
    .dot.yellow { background: #febc2e; }
    .dot.green { background: #28c840; }

    .hero-image {
      width: 100%;
      height: auto;
      display: block;
    }

    .hero-blur-bg {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 120%;
      height: 120%;
      background: radial-gradient(circle, rgba(94, 92, 230, 0.15) 0%, transparent 70%);
      z-index: -1;
      filter: blur(40px);
    }

    /* Features Section */
    .features-section {
      padding: 100px 0;
      background-color: #f5f5f7;
    }

    [data-theme="dark"] .features-section {
      background-color: #161617;
    }

    .section-badge {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #0071e3;
      margin-bottom: 16px;
      text-align: center;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
    }

    .feature-card {
      background: white;
      padding: 40px;
      border-radius: 20px;
      transition: all 0.4s cubic-bezier(0.12, 0, 0.39, 0);
      border: 1px solid transparent;
    }

    [data-theme="dark"] .feature-card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
    }

    .feature-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
    }

    .feature-icon {
      font-size: 32px;
      margin-bottom: 20px;
    }

    .feature-card h3 {
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .feature-card p {
      color: #86868b;
      line-height: 1.5;
    }

    /* Shortcut Section */
    .shortcut-section {
      padding: 120px 0;
      text-align: center;
    }

    .shortcut-info h2 {
      font-size: 48px;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .shortcut-info p {
      font-size: 20px;
      color: #86868b;
      margin-bottom: 60px;
    }

    .shortcut-viz {
      background: #f5f5f7;
      border-radius: 30px;
      padding: 40px;
    }

    [data-theme="dark"] .shortcut-viz {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .viz-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 24px 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    [data-theme="dark"] .viz-row {
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .viz-row:last-child {
      border-bottom: none;
    }

    .viz-label {
      font-weight: 500;
      font-size: 18px;
    }

    .viz-keys {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    kbd {
      background: white;
      border-radius: 8px;
      border: 1px solid #d2d2d7;
      box-shadow: 0 2px 0 #d2d2d7;
      color: #1d1d1f;
      display: inline-block;
      font-family: inherit;
      font-size: 14px;
      font-weight: 600;
      padding: 8px 12px;
      min-width: 40px;
      text-align: center;
    }

    [data-theme="dark"] kbd {
      background: #333;
      border: 1px solid #444;
      box-shadow: 0 2px 0 #111;
      color: #fff;
    }

    .typing-cursor {
      color: #0071e3;
      animation: blink 1s step-end infinite;
      font-weight: 300;
      font-size: 24px;
    }

    @keyframes blink {
      from, to { opacity: 1; }
      50% { opacity: 0; }
    }

    .typing-text {
      color: #86868b;
      font-style: italic;
    }

    /* Trust Section */
    .trust-section {
      padding: 100px 0 140px;
    }

    .trust-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .trust-item {
      text-align: center;
      padding: 40px;
    }

    .trust-icon {
      color: #0071e3;
      margin-bottom: 24px;
    }

    .trust-item h4 {
      font-size: 20px;
      margin-bottom: 12px;
    }

    .trust-item p {
      color: #86868b;
      line-height: 1.5;
    }

    /* Animations */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    /* Responsive */
    @media (max-width: 900px) {
      .hero-content {
        grid-template-columns: 1fr;
        text-align: center;
      }
      
      .hero-text h1 {
        font-size: 48px;
      }
      
      .cta-group {
        justify-content: center;
      }
      
      .trust-grid {
        grid-template-columns: 1fr;
      }

      .mac-window-mockup {
        transform: none;
      }
    }

    @media (max-width: 600px) {
      .container {
        padding: 0 24px;
      }
      
      .hero-text h1 {
        font-size: 40px;
      }
      
      .viz-row {
        flex-direction: column;
        gap: 16px;
      }
    }
  </style>

  <script is:inline>
    // Initial call for animations handled by script.js via .fade-up-entry
  </script>
</BaseLayout>
