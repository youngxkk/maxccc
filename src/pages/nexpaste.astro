            linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.20));
        }

        .reveal {
          opacity: 0;
          transform: translateY(24px);
          transition: opacity 720ms ease, transform 720ms ease;
        }

        .reveal.visible {
          opacity: 1;
          transform: translateY(0);
        }

        @keyframes floatIcon {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(-8px); }
        }

        @keyframes keyPress {
          0%, 62%, 100% { transform: translateY(0); }
          70% { transform: translateY(8px); }
        }

        @keyframes marqueeScroll {
          from { transform: translateX(0); }
          to { transform: translateX(calc(-50% - 6px)); }
        }

        @keyframes scrollThumb {
          from { transform: translateX(0); }
          to { transform: translateX(70px); }
        }

        @media (prefers-reduced-motion: reduce) {
          *,
          *::before,
          *::after {
            animation-duration: 1ms !important;
            animation-iteration-count: 1 !important;
            scroll-behavior: auto !important;
            transition-duration: 1ms !important;
          }
        }

        @media (max-width: 900px) {
          .hero {
            min-height: auto;
            padding-top: 92px;
          }

          .real-controls {
            display: grid;
          }

          .real-search {
            width: 100%;
          }

          .horizontal-shell {
            overflow-x: auto;
          }

          .horizontal-track {
            animation: none;
          }

          .split,
          .pro-card {
            grid-template-columns: 1fr;
          }

          .tile-grid {
            grid-template-columns: 1fr;
          }
        }

        @media (max-width: 560px) {
          section {
            padding: 70px 16px;
          }

          .hero {
            padding-left: 16px;
            padding-right: 16px;
          }

          .app-icon {
            width: 72px;
            height: 72px;
            border-radius: 18px;
          }

          .eyebrow,
          .section-kicker {
            font-size: 16px;
          }

          .cta-row {
            flex-direction: column;
            align-items: center;
            gap: 12px;
            font-size: 16px;
          }

          .primary-link,
          .secondary-link {
            width: min(280px, 100%);
          }

          .mac-window {
            border-radius: 20px;
          }

          .split-text,
          .tile,
          .pro-item {
            padding: 28px;
          }

          .command-visual {
            min-height: 360px;
          }

        }
  </style>

  <script is:inline>
    const reveals = document.querySelectorAll(".reveal");
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.16 });

        reveals.forEach((node, index) => {
          node.style.transitionDelay = `${Math.min(index % 4, 3) * 80}ms`;
          observer.observe(node);
        });

        const stage = document.querySelector(".hero-stage");
        const windowMock = document.querySelector(".mac-window");

        if (stage && windowMock && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          stage.addEventListener("pointermove", (event) => {
            const rect = stage.getBoundingClientRect();
            const x = (event.clientX - rect.left) / rect.width - 0.5;
            const y = (event.clientY - rect.top) / rect.height - 0.5;
            windowMock.style.transform = `rotateX(${3 - y * 4}deg) rotateY(${x * 5}deg) translateY(-2px)`;
          });

          stage.addEventListener("pointerleave", () => {
            windowMock.style.transform = "rotateX(3deg) rotateY(0deg) translateY(0)";
          });
        }
  </script>
</BaseLayout>
