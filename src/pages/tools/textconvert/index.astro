---
import ToolLayout from "../../../layouts/ToolLayout.astro";
import { toolDictionaries } from "../../../i18n/dictionaries";

const toolPayload = JSON.stringify(toolDictionaries.textconvert).replace(/</g, "\\u003c");
---

<ToolLayout
  title="文本转换工具 - ToolKit.Max | 大小写、倒序、空格处理"
  description="ToolKit.Max 文本转换工具，提供全大写、全小写、文本倒序、去除空格等多种文本处理转换功能。极简高效，隐私安全。"
  canonical="https://maxc.cc/tools/textconvert/"
  icon="🔀"
  maxWidthClass="max-w-4xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title">文本转换工具</h1>
    <p class="tool-subtitle" id="tool-subtitle">大小写、倒序、空格处理专家</p>
  </header>

  <section class="tool-card rounded-[32px] p-6 md:p-8 animate-up">
    <div class="space-y-6">
      <div class="relative">
        <textarea id="text-input" class="w-full h-72 p-6 rounded-[26px] tool-panel-muted focus:outline-none focus:ring-2 focus:ring-blue-500/50 text-lg" placeholder="请在此输入或粘贴待转换的文本..."></textarea>
        <button id="copy-button" class="absolute bottom-4 right-4 p-4 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-300 hover:scale-105 transition-transform">
          <span id="copy-icon">⧉</span>
        </button>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <button id="upper-button" class="py-3 px-4 tool-panel-muted hover:bg-blue-600 hover:text-white font-bold rounded-xl transition-colors">全大写</button>
        <button id="lower-button" class="py-3 px-4 tool-panel-muted hover:bg-blue-600 hover:text-white font-bold rounded-xl transition-colors">全小写</button>
        <button id="reverse-button" class="py-3 px-4 tool-panel-muted hover:bg-blue-600 hover:text-white font-bold rounded-xl transition-colors">倒序</button>
        <button id="trim-button" class="py-3 px-4 tool-panel-muted hover:bg-blue-600 hover:text-white font-bold rounded-xl transition-colors">去除首尾空格</button>
      </div>
    </div>
  </section>

  <script id="tool-i18n" type="application/json" set:html={toolPayload}></script>
  <script is:inline>
    (() => {
      const shell = window.ToolShell;
      const { messages: translations } = JSON.parse(document.getElementById("tool-i18n").textContent);

      const elements = {
        title: document.getElementById("tool-title"),
        subtitle: document.getElementById("tool-subtitle"),
        input: document.getElementById("text-input"),
        upper: document.getElementById("upper-button"),
        lower: document.getElementById("lower-button"),
        reverse: document.getElementById("reverse-button"),
        trim: document.getElementById("trim-button"),
        copy: document.getElementById("copy-button"),
        copyIcon: document.getElementById("copy-icon")
      };

      function getText() {
        return translations[shell.getLang()] || translations.en;
      }

      function syncCopy() {
        const t = getText();
        elements.title.textContent = t.title;
        elements.subtitle.textContent = t.desc;
        elements.input.placeholder = t.placeholder;
        elements.upper.textContent = t.upper;
        elements.lower.textContent = t.lower;
        elements.reverse.textContent = t.reverse;
        elements.trim.textContent = t.trim;
      }

      function updateText(next) {
        elements.input.value = next;
      }

      async function copyText() {
        await navigator.clipboard.writeText(elements.input.value);
        elements.copyIcon.textContent = "✓";
        window.setTimeout(() => {
          elements.copyIcon.textContent = "⧉";
        }, 1800);
      }

      elements.upper.addEventListener("click", () => updateText(elements.input.value.toUpperCase()));
      elements.lower.addEventListener("click", () => updateText(elements.input.value.toLowerCase()));
      elements.reverse.addEventListener("click", () => updateText(elements.input.value.split("").reverse().join("")));
      elements.trim.addEventListener("click", () => updateText(elements.input.value.trim()));
      elements.copy.addEventListener("click", copyText);

      shell.subscribeLang(syncCopy);
      syncCopy();
    })();
  </script>
</ToolLayout>
