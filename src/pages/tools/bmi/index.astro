---
import ToolLayout from "../../../layouts/ToolLayout.astro";
import { toolDictionaries } from "../../../i18n/dictionaries";

const toolPayload = JSON.stringify(toolDictionaries.bmi).replace(/</g, "\\u003c");
---

<ToolLayout
  title="BMI 计算器 - ToolKit.Max | 健康体重指数快速估算"
  description="ToolKit.Max BMI 计算器，帮助你快速根据身高和体重估算 BMI 指数。所有计算都在本地完成，简洁直观。"
  canonical="https://maxc.cc/tools/bmi/"
  icon="🏃"
  maxWidthClass="max-w-3xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title">BMI 计算器</h1>
    <p class="tool-subtitle" id="tool-subtitle">快速估算你的健康体重指数</p>
  </header>

  <section class="tool-card rounded-[32px] p-8 md:p-10 animate-up">
    <div class="space-y-6">
      <div class="text-center py-8 bg-blue-50 dark:bg-blue-900/20 rounded-[28px]">
        <div id="bmi-output" class="text-5xl font-black text-blue-600">22.9</div>
        <div id="bmi-label" class="text-xs font-bold text-blue-400 uppercase tracking-widest mt-2">BMI 指数</div>
      </div>

      <div class="space-y-6">
        <div class="space-y-3">
          <div class="flex justify-between text-sm font-medium">
            <span id="height-label">身高</span>
            <span><span id="height-value">175</span> cm</span>
          </div>
          <input id="height-input" type="range" min="100" max="220" value="175" class="tool-range" />
        </div>

        <div class="space-y-3">
          <div class="flex justify-between text-sm font-medium">
            <span id="weight-label">体重</span>
            <span><span id="weight-value">70</span> kg</span>
          </div>
          <input id="weight-input" type="range" min="30" max="150" value="70" class="tool-range" />
        </div>
      </div>
    </div>
  </section>

  <script id="tool-i18n" type="application/json" set:html={toolPayload}></script>
  <script is:inline>
    (() => {
      const shell = window.ToolShell;
      const { messages: translations } = JSON.parse(document.getElementById("tool-i18n").textContent);

      const elements = {
        title: document.getElementById("tool-title"),
        subtitle: document.getElementById("tool-subtitle"),
        output: document.getElementById("bmi-output"),
        bmiLabel: document.getElementById("bmi-label"),
        heightLabel: document.getElementById("height-label"),
        weightLabel: document.getElementById("weight-label"),
        heightValue: document.getElementById("height-value"),
        weightValue: document.getElementById("weight-value"),
        heightInput: document.getElementById("height-input"),
        weightInput: document.getElementById("weight-input")
      };

      function getText() {
        return translations[shell.getLang()] || translations.en;
      }

      function syncCopy() {
        const t = getText();
        elements.title.textContent = t.title;
        elements.subtitle.textContent = t.desc;
        elements.bmiLabel.textContent = t.bmi;
        elements.heightLabel.textContent = t.height;
        elements.weightLabel.textContent = t.weight;
      }

      function updateBMI() {
        const height = Number(elements.heightInput.value);
        const weight = Number(elements.weightInput.value);
        const bmi = (weight / ((height / 100) ** 2)).toFixed(1);

        elements.heightValue.textContent = String(height);
        elements.weightValue.textContent = String(weight);
        elements.output.textContent = bmi;
      }

      elements.heightInput.addEventListener("input", updateBMI);
      elements.weightInput.addEventListener("input", updateBMI);
      shell.subscribeLang(syncCopy);

      syncCopy();
      updateBMI();
    })();
  </script>
</ToolLayout>
