---
import ToolLayout from "../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="图片去背景 - ToolKit.Max | 本地 AI 智能抠图"
  description="ToolKit.Max 图片去背景工具，直接在浏览器本地完成 AI 抠图，不上传服务器，支持透明 PNG 下载。"
  canonical="https://maxc.cc/tools/remove-bg.html"
  icon="🖼️"
  maxWidthClass="max-w-6xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title">图片去背景</h1>
    <p class="tool-subtitle" id="tool-subtitle">纯本地 AI 智能抠图，不上传服务器</p>
  </header>

  <style is:inline>
    .remove-bg-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 1.5rem;
    }

    .checkerboard {
      background-image:
        linear-gradient(45deg, rgba(148, 163, 184, 0.18) 25%, transparent 25%),
        linear-gradient(-45deg, rgba(148, 163, 184, 0.18) 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, rgba(148, 163, 184, 0.18) 75%),
        linear-gradient(-45deg, transparent 75%, rgba(148, 163, 184, 0.18) 75%);
      background-size: 22px 22px;
      background-position: 0 0, 0 11px, 11px -11px, -11px 0px;
    }

    .image-stage {
      min-height: 320px;
      border-radius: 28px;
      border: 1px dashed rgba(148, 163, 184, 0.28);
      display: grid;
      place-items: center;
      overflow: hidden;
    }

    .image-stage img {
      max-width: 100%;
      max-height: 420px;
      object-fit: contain;
      display: block;
    }

    .tone-chip {
      width: 32px;
      height: 32px;
      border-radius: 999px;
      border: 2px solid transparent;
      cursor: pointer;
      transition: transform 0.18s ease, border-color 0.18s ease;
    }

    .tone-chip.active {
      border-color: rgba(37, 99, 235, 0.9);
      transform: scale(1.05);
    }

    @media (max-width: 960px) {
      .remove-bg-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="remove-bg-grid animate-up">
    <section class="tool-card rounded-[32px] p-6 md:p-8">
      <div class="space-y-6">
        <div id="drop-zone" class="image-stage checkerboard tool-panel-muted text-center p-8 cursor-pointer transition-all">
          <div id="drop-empty" class="space-y-4">
            <div class="mx-auto w-20 h-20 rounded-[24px] bg-blue-50 text-blue-600 flex items-center justify-center text-4xl shadow-sm">🪄</div>
            <div>
              <h2 id="drop-title" class="text-2xl font-bold mb-2">点击或拖拽图片到这里</h2>
              <p id="drop-desc" class="text-slate-500">支持 PNG、JPG、WEBP。首次处理会下载 AI 模型，时间会稍长一些。</p>
            </div>
            <button id="pick-button" class="px-6 py-3 bg-blue-600 text-white font-bold rounded-2xl shadow-lg shadow-blue-600/20">选择图片</button>
          </div>
          <img id="source-preview" alt="Source preview" class="hidden" />
          <input id="file-input" type="file" accept="image/png,image/jpeg,image/webp" class="hidden" />
        </div>

        <div class="flex flex-wrap gap-3">
          <button id="process-button" class="px-5 py-3 bg-slate-900 dark:bg-blue-600 text-white font-bold rounded-2xl shadow-lg disabled:opacity-50 disabled:cursor-not-allowed" disabled>开始去背景</button>
          <button id="reset-button" class="px-5 py-3 tool-panel-muted font-bold rounded-2xl" disabled>重置</button>
          <button id="download-button" class="px-5 py-3 tool-panel-muted font-bold rounded-2xl" disabled>下载 PNG</button>
        </div>

        <div class="rounded-[24px] tool-panel-muted p-5">
          <div class="flex justify-between items-center gap-4 mb-3">
            <div>
              <div id="status-title" class="font-bold text-lg">等待图片</div>
              <p id="status-text" class="text-sm text-slate-500">上传图片后就可以在本地开始 AI 抠图。</p>
            </div>
            <div id="status-badge" class="px-3 py-1.5 rounded-full bg-slate-900 text-white text-xs font-bold uppercase tracking-[0.18em]">Idle</div>
          </div>
          <div class="h-2 rounded-full bg-slate-200 dark:bg-slate-800 overflow-hidden">
            <div id="progress-bar" class="h-full w-0 bg-blue-600 transition-all duration-300"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="tool-card rounded-[32px] p-6 md:p-8">
      <div class="space-y-5">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 id="result-title" class="text-2xl font-bold">结果预览</h2>
            <p id="result-desc" class="text-slate-500">透明背景预览和不同底色检查。</p>
          </div>
          <div class="flex items-center gap-2">
            <button class="tone-chip active checkerboard" data-tone="checker"></button>
            <button class="tone-chip bg-white border border-slate-200" data-tone="light"></button>
            <button class="tone-chip bg-slate-900" data-tone="dark"></button>
            <button class="tone-chip bg-gradient-to-br from-pink-400 to-orange-300" data-tone="warm"></button>
          </div>
        </div>

        <div id="result-stage" class="image-stage checkerboard tool-panel-muted p-6">
          <div id="result-empty" class="text-center text-slate-400">
            <div class="text-4xl mb-3">🌫️</div>
            <p id="result-empty-text">处理完成后，透明背景结果会显示在这里。</p>
          </div>
          <img id="result-preview" alt="Removed background preview" class="hidden" />
        </div>

        <div class="rounded-[24px] tool-panel-muted p-5 space-y-3">
          <div class="font-bold text-lg" id="privacy-title">隐私说明</div>
          <p id="privacy-text" class="text-sm text-slate-500 leading-relaxed">整张图片会在你的浏览器里本地处理，不会上传到你的服务器。首次使用会额外下载模型文件并缓存到浏览器里。</p>
        </div>
      </div>
    </section>
  </div>

  <script type="module">
    import { removeBackground } from "@imgly/background-removal";

    const translations = {
      "zh-CN": {
        title: "图片去背景",
        subtitle: "纯本地 AI 智能抠图，不上传服务器",
        dropTitle: "点击或拖拽图片到这里",
        dropDesc: "支持 PNG、JPG、WEBP。默认使用轻量模型，首次处理会下载 AI 模型。",
        choose: "选择图片",
        process: "开始去背景",
        processing: "处理中...",
        reset: "重置",
        download: "下载 PNG",
        waitingTitle: "等待图片",
        waitingText: "上传图片后就可以在本地开始 AI 抠图。",
        readyTitle: "图片已就绪",
        readyText: "现在可以开始去背景了。",
        workingTitle: "正在进行 AI 抠图",
        workingText: "第一次处理需要下载轻量模型，速度更快，但复杂边缘可能略有损失。",
        doneTitle: "去背景完成",
        doneText: "现在可以切换预览底色，或者直接下载透明 PNG。",
        failedTitle: "处理失败",
        failedText: "这张图暂时没能成功抠图，请换一张边缘更清晰的图片再试。",
        resultTitle: "结果预览",
        resultDesc: "透明背景预览和不同底色检查。",
        resultEmpty: "处理完成后，透明背景结果会显示在这里。",
        privacyTitle: "隐私说明",
        privacyText: "整张图片会在你的浏览器里本地处理，不会上传到你的服务器。首次使用会额外下载模型文件并缓存到浏览器里。",
        idle: "Idle",
        ready: "Ready",
        working: "Running",
        done: "Done",
        failed: "Error",
        invalidFile: "请选择 PNG、JPG 或 WEBP 图片。",
        downloadName: "removed-background.png"
      },
      en: {
        title: "Remove Background",
        subtitle: "Local AI background removal, no server upload",
        dropTitle: "Click or drag an image here",
        dropDesc: "Supports PNG, JPG and WEBP. Uses the lightweight model by default for faster loading.",
        choose: "Choose Image",
        process: "Remove Background",
        processing: "Processing...",
        reset: "Reset",
        download: "Download PNG",
        waitingTitle: "Waiting for image",
        waitingText: "Upload an image to start local AI background removal.",
        readyTitle: "Image ready",
        readyText: "You can start removing the background now.",
        workingTitle: "Running AI background removal",
        workingText: "The first run downloads the lightweight model for faster startup, with slightly lower edge quality on difficult images.",
        doneTitle: "Background removed",
        doneText: "You can now switch preview tones or download the transparent PNG.",
        failedTitle: "Processing failed",
        failedText: "This image could not be processed right now. Try another image with clearer edges.",
        resultTitle: "Preview",
        resultDesc: "Transparent result preview with different surface tones.",
        resultEmpty: "The transparent result will appear here after processing.",
        privacyTitle: "Privacy",
        privacyText: "Everything runs locally in your browser. The image is not uploaded to your server. The first run downloads and caches the model in the browser.",
        idle: "Idle",
        ready: "Ready",
        working: "Running",
        done: "Done",
        failed: "Error",
        invalidFile: "Please choose a PNG, JPG or WEBP image.",
        downloadName: "removed-background.png"
      }
    };

    const shell = window.ToolShell;
    const state = {
      file: null,
      sourceUrl: "",
      resultUrl: "",
      resultBlob: null,
      tone: "checker"
    };

    const elements = {
      title: document.getElementById("tool-title"),
      subtitle: document.getElementById("tool-subtitle"),
      dropTitle: document.getElementById("drop-title"),
      dropDesc: document.getElementById("drop-desc"),
      pickButton: document.getElementById("pick-button"),
      processButton: document.getElementById("process-button"),
      resetButton: document.getElementById("reset-button"),
      downloadButton: document.getElementById("download-button"),
      statusTitle: document.getElementById("status-title"),
      statusText: document.getElementById("status-text"),
      statusBadge: document.getElementById("status-badge"),
      progressBar: document.getElementById("progress-bar"),
      resultTitle: document.getElementById("result-title"),
      resultDesc: document.getElementById("result-desc"),
      resultEmptyText: document.getElementById("result-empty-text"),
      privacyTitle: document.getElementById("privacy-title"),
      privacyText: document.getElementById("privacy-text"),
      fileInput: document.getElementById("file-input"),
      dropZone: document.getElementById("drop-zone"),
      dropEmpty: document.getElementById("drop-empty"),
      sourcePreview: document.getElementById("source-preview"),
      resultStage: document.getElementById("result-stage"),
      resultEmpty: document.getElementById("result-empty"),
      resultPreview: document.getElementById("result-preview")
    };

    function t() {
      return translations[shell.getLang()] || translations.en;
    }

    function syncCopy() {
      const copy = t();
      elements.title.textContent = copy.title;
      elements.subtitle.textContent = copy.subtitle;
      elements.dropTitle.textContent = copy.dropTitle;
      elements.dropDesc.textContent = copy.dropDesc;
      elements.pickButton.textContent = copy.choose;
      elements.processButton.textContent = state.resultBlob ? copy.process : copy.process;
      elements.resetButton.textContent = copy.reset;
      elements.downloadButton.textContent = copy.download;
      elements.resultTitle.textContent = copy.resultTitle;
      elements.resultDesc.textContent = copy.resultDesc;
      elements.resultEmptyText.textContent = copy.resultEmpty;
      elements.privacyTitle.textContent = copy.privacyTitle;
      elements.privacyText.textContent = copy.privacyText;
      if (!state.file) {
        setStatus("idle");
      }
    }

    function setProgress(value) {
      elements.progressBar.style.width = `${Math.max(0, Math.min(100, value))}%`;
    }

    function setStatus(kind) {
      const copy = t();
      const map = {
        idle: { title: copy.waitingTitle, text: copy.waitingText, badge: copy.idle, className: "bg-slate-900 text-white" },
        ready: { title: copy.readyTitle, text: copy.readyText, badge: copy.ready, className: "bg-blue-600 text-white" },
        working: { title: copy.workingTitle, text: copy.workingText, badge: copy.working, className: "bg-amber-500 text-white" },
        done: { title: copy.doneTitle, text: copy.doneText, badge: copy.done, className: "bg-emerald-500 text-white" },
        failed: { title: copy.failedTitle, text: copy.failedText, badge: copy.failed, className: "bg-rose-500 text-white" }
      };
      const current = map[kind];
      elements.statusTitle.textContent = current.title;
      elements.statusText.textContent = current.text;
      elements.statusBadge.textContent = current.badge;
      elements.statusBadge.className = `px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-[0.18em] ${current.className}`;
    }

    function releaseUrl(url) {
      if (url) URL.revokeObjectURL(url);
    }

    function resetState() {
      releaseUrl(state.sourceUrl);
      releaseUrl(state.resultUrl);
      state.file = null;
      state.sourceUrl = "";
      state.resultUrl = "";
      state.resultBlob = null;

      elements.fileInput.value = "";
      elements.dropEmpty.classList.remove("hidden");
      elements.sourcePreview.classList.add("hidden");
      elements.sourcePreview.removeAttribute("src");
      elements.resultEmpty.classList.remove("hidden");
      elements.resultPreview.classList.add("hidden");
      elements.resultPreview.removeAttribute("src");
      elements.processButton.disabled = true;
      elements.resetButton.disabled = true;
      elements.downloadButton.disabled = true;
      setStatus("idle");
      setProgress(0);
    }

    function setTone(tone) {
      state.tone = tone;
      document.querySelectorAll(".tone-chip").forEach((chip) => {
        chip.classList.toggle("active", chip.dataset.tone === tone);
      });

      const stage = elements.resultStage;
      stage.classList.remove("checkerboard", "bg-white", "bg-slate-950", "bg-gradient-to-br", "from-pink-400", "to-orange-300");
      if (tone === "checker") {
        stage.classList.add("checkerboard");
      } else if (tone === "light") {
        stage.classList.add("bg-white");
      } else if (tone === "dark") {
        stage.classList.add("bg-slate-950");
      } else if (tone === "warm") {
        stage.classList.add("bg-gradient-to-br", "from-pink-400", "to-orange-300");
      }
    }

    function loadFile(file) {
      if (!file || !file.type.startsWith("image/")) {
        alert(t().invalidFile);
        return;
      }

      releaseUrl(state.sourceUrl);
      state.file = file;
      state.sourceUrl = URL.createObjectURL(file);
      state.resultBlob = null;
      releaseUrl(state.resultUrl);
      state.resultUrl = "";

      elements.sourcePreview.src = state.sourceUrl;
      elements.sourcePreview.classList.remove("hidden");
      elements.dropEmpty.classList.add("hidden");
      elements.resultPreview.classList.add("hidden");
      elements.resultEmpty.classList.remove("hidden");
      elements.processButton.disabled = false;
      elements.resetButton.disabled = false;
      elements.downloadButton.disabled = true;
      setProgress(0);
      setStatus("ready");
    }

    async function processImage() {
      if (!state.file) return;
      const copy = t();

      elements.processButton.disabled = true;
      elements.processButton.textContent = copy.processing;
      setStatus("working");
      setProgress(12);

      try {
        const blob = await removeBackground(state.file, {
          model: "small",
          output: { format: "image/png" },
          progress: (key, current, total) => {
            if (typeof current === "number" && typeof total === "number" && total > 0) {
              const progress = 12 + Math.round((current / total) * 78);
              setProgress(progress);
            }
          }
        });

        releaseUrl(state.resultUrl);
        state.resultBlob = blob;
        state.resultUrl = URL.createObjectURL(blob);

        elements.resultPreview.src = state.resultUrl;
        elements.resultPreview.classList.remove("hidden");
        elements.resultEmpty.classList.add("hidden");
        elements.downloadButton.disabled = false;
        setProgress(100);
        setStatus("done");
      } catch (error) {
        console.error(error);
        setProgress(0);
        setStatus("failed");
      } finally {
        elements.processButton.disabled = false;
        elements.processButton.textContent = copy.process;
      }
    }

    function downloadResult() {
      if (!state.resultBlob) return;
      const link = document.createElement("a");
      link.href = state.resultUrl;
      link.download = t().downloadName;
      link.click();
    }

    elements.pickButton.addEventListener("click", (event) => {
      event.preventDefault();
      elements.fileInput.click();
    });

    elements.fileInput.addEventListener("change", (event) => {
      loadFile(event.target.files?.[0] || null);
    });

    elements.dropZone.addEventListener("dragover", (event) => {
      event.preventDefault();
      elements.dropZone.classList.add("border-blue-500");
    });

    elements.dropZone.addEventListener("dragleave", () => {
      elements.dropZone.classList.remove("border-blue-500");
    });

    elements.dropZone.addEventListener("drop", (event) => {
      event.preventDefault();
      elements.dropZone.classList.remove("border-blue-500");
      loadFile(event.dataTransfer?.files?.[0] || null);
    });

    elements.processButton.addEventListener("click", processImage);
    elements.resetButton.addEventListener("click", resetState);
    elements.downloadButton.addEventListener("click", downloadResult);
    document.querySelectorAll(".tone-chip").forEach((chip) => chip.addEventListener("click", () => setTone(chip.dataset.tone)));
    window.addEventListener("tool:langchange", syncCopy);

    syncCopy();
    setTone("checker");
    resetState();
  </script>
</ToolLayout>
