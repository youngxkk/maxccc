---
import ToolLayout from "../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="文本转换工具 - ToolKit.Max | 大小写、倒序、空格处理"
  description="ToolKit.Max 文本转换工具，提供全大写、全小写、文本倒序、去除空格等多种文本处理转换功能。极简高效，隐私安全。"
  canonical="https://maxc.cc/tools/textconvert.html"
  icon="🔀"
  maxWidthClass="max-w-4xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title">文本转换工具</h1>
    <p class="tool-subtitle" id="tool-subtitle">大小写、倒序、空格处理专家</p>
  </header>

  <div id="tool-root" class="animate-up"></div>

  <script type="text/babel" is:inline>
    const { useEffect, useState } = React;
    const shell = window.ToolShell;

    const translations = {
      "zh-CN": {
        title: "文本转换工具",
        desc: "大小写、倒序、空格处理专家",
        placeholder: "请在此输入或粘贴待转换的文本...",
        btn_upper: "全大写",
        btn_lower: "全小写",
        btn_reverse: "倒序",
        btn_trim: "去除首尾空格",
        copied: "已复制"
      },
      en: {
        title: "Text Converter",
        desc: "Case, Reverse, and Trim expert",
        placeholder: "Paste your text here to transform...",
        btn_upper: "UPPERCASE",
        btn_lower: "lowercase",
        btn_reverse: "Reverse",
        btn_trim: "Trim Spaces",
        copied: "Copied"
      }
    };

    const Icons = {
      Copy: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" /></svg>,
      Check: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
    };

    function syncHero(lang) {
      const t = translations[lang] || translations.en;
      document.getElementById("tool-title").textContent = t.title;
      document.getElementById("tool-subtitle").textContent = t.desc;
    }

    const App = () => {
      const [lang, setLang] = useState(shell.getLang());
      const [text, setText] = useState("");
      const [copied, setCopied] = useState(false);
      const t = translations[lang] || translations.en;

      useEffect(() => syncHero(lang), [lang]);
      useEffect(() => shell.subscribeLang(setLang), []);

      const copyToClipboard = async () => {
        await navigator.clipboard.writeText(text);
        setCopied(true);
        setTimeout(() => setCopied(false), 2000);
      };

      return (
        <div className="tool-card rounded-[32px] p-6 md:p-8">
          <div className="space-y-6">
            <div className="relative">
              <textarea
                value={text}
                onChange={(e) => setText(e.target.value)}
                placeholder={t.placeholder}
                className="w-full h-72 p-6 rounded-[26px] tool-panel-muted focus:outline-none focus:ring-2 focus:ring-blue-500/50 text-lg"
              />
              <button onClick={copyToClipboard} className="absolute bottom-4 right-4 p-4 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-300 hover:scale-105 transition-transform">
                {copied ? <Icons.Check /> : <Icons.Copy />}
              </button>
            </div>

            <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
              <button onClick={() => setText(text.toUpperCase())} className="py-3 px-4 tool-panel-muted hover:bg-blue-600 hover:text-white font-bold rounded-xl transition-colors">{t.btn_upper}</button>
              <button onClick={() => setText(text.toLowerCase())} className="py-3 px-4 tool-panel-muted hover:bg-blue-600 hover:text-white font-bold rounded-xl transition-colors">{t.btn_lower}</button>
              <button onClick={() => setText(text.split('').reverse().join(''))} className="py-3 px-4 tool-panel-muted hover:bg-blue-600 hover:text-white font-bold rounded-xl transition-colors">{t.btn_reverse}</button>
              <button onClick={() => setText(text.trim())} className="py-3 px-4 tool-panel-muted hover:bg-blue-600 hover:text-white font-bold rounded-xl transition-colors">{t.btn_trim}</button>
            </div>
          </div>
        </div>
      );
    };

    ReactDOM.createRoot(document.getElementById("tool-root")).render(<App />);
    syncHero(shell.getLang());
  </script>
</ToolLayout>
