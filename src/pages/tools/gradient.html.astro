---
import ToolLayout from "../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="CSS 渐变生成器 - ToolKit.Max | 可视化生成 CSS 渐变代码"
  description="ToolKit.Max CSS 渐变生成器，可视化生成线性渐变和径向渐变代码。支持多色渐变、角度调整、实时预览，一键复制 CSS 代码。"
  canonical="https://maxc.cc/tools/gradient.html"
  icon="🎨"
  maxWidthClass="max-w-5xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title">CSS 渐变生成器</h1>
    <p class="tool-subtitle" id="tool-subtitle">可视化生成精美的 CSS 渐变代码</p>
  </header>

  <div id="tool-root" class="animate-up"></div>

  <script type="text/babel" is:inline>
    const { useEffect, useState } = React;
    const shell = window.ToolShell;

    const presets = [
      { colors: [{ color: '#667eea', position: 0 }, { color: '#764ba2', position: 100 }], angle: 135 },
      { colors: [{ color: '#f093fb', position: 0 }, { color: '#f5576c', position: 100 }], angle: 135 },
      { colors: [{ color: '#4facfe', position: 0 }, { color: '#00f2fe', position: 100 }], angle: 135 },
      { colors: [{ color: '#43e97b', position: 0 }, { color: '#38f9d7', position: 100 }], angle: 135 },
      { colors: [{ color: '#ff6e7f', position: 0 }, { color: '#bfe9ff', position: 100 }], angle: 135 }
    ];

    const translations = {
      "zh-CN": {
        title: "CSS 渐变生成器",
        desc: "可视化生成精美的 CSS 渐变代码",
        angle: "角度",
        add_color: "添加颜色",
        random_gradient: "随机渐变",
        css_code: "CSS 代码",
        copied: "已复制"
      },
      en: {
        title: "CSS Gradient Generator",
        desc: "Visually create beautiful CSS gradients",
        angle: "Angle",
        add_color: "Add Color",
        random_gradient: "Random",
        css_code: "CSS Code",
        copied: "Copied"
      }
    };

    const Icons = {
      Copy: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" /></svg>,
      Check: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12" /></svg>,
      Plus: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>,
      Trash: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /></svg>
    };

    function syncHero(lang) {
      const t = translations[lang] || translations.en;
      document.getElementById("tool-title").textContent = t.title;
      document.getElementById("tool-subtitle").textContent = t.desc;
    }

    const App = () => {
      const [lang, setLang] = useState(shell.getLang());
      const [angle, setAngle] = useState(135);
      const [colors, setColors] = useState([
        { color: '#667eea', position: 0 },
        { color: '#764ba2', position: 100 }
      ]);
      const [copied, setCopied] = useState(false);
      const t = translations[lang] || translations.en;

      useEffect(() => syncHero(lang), [lang]);
      useEffect(() => shell.subscribeLang(setLang), []);

      const gradient = `linear-gradient(${angle}deg, ${[...colors].sort((a, b) => a.position - b.position).map((item) => `${item.color} ${item.position}%`).join(", ")})`;

      const updateColor = (index, field, value) => {
        const next = [...colors];
        next[index][field] = field === "position" ? parseInt(value, 10) : value;
        setColors(next);
      };

      const addColor = () => {
        if (colors.length < 5) {
          setColors([...colors, { color: "#ff6b6b", position: 50 }]);
        }
      };

      const randomGradient = () => {
        const preset = presets[Math.floor(Math.random() * presets.length)];
        setAngle(preset.angle);
        setColors(preset.colors);
      };

      const copyToClipboard = async () => {
        await navigator.clipboard.writeText(`background: ${gradient};`);
        setCopied(true);
        setTimeout(() => setCopied(false), 2000);
      };

      return (
        <div className="space-y-6">
          <div className="tool-card rounded-[32px] p-8">
            <div className="flex justify-between items-center mb-4">
              <div className="text-sm font-bold uppercase tracking-[0.18em] text-slate-400">Preview</div>
              <button onClick={randomGradient} className="px-4 py-2 bg-gradient-to-r from-purple-500 to-pink-500 text-white rounded-xl font-bold shadow-lg">
                {t.random_gradient}
              </button>
            </div>
            <div className="w-full h-64 rounded-[28px] shadow-inner" style={{ background: gradient }}></div>
          </div>

          <div className="tool-card rounded-[32px] p-8">
            <div className="space-y-6">
              <div className="space-y-3">
                <div className="flex justify-between font-bold">
                  <span>{t.angle}</span>
                  <span className="text-blue-600 font-mono">{angle}°</span>
                </div>
                <input type="range" min="0" max="360" value={angle} onChange={(e) => setAngle(Number(e.target.value))} className="tool-range" />
              </div>

              <div className="space-y-4">
                {colors.map((item, index) => (
                  <div key={index} className="flex items-center gap-4 p-4 rounded-2xl tool-panel-muted">
                    <input type="color" value={item.color} onChange={(e) => updateColor(index, "color", e.target.value)} />
                    <div className="flex-1 space-y-2">
                      <div className="flex justify-between text-sm">
                        <span className="font-mono font-bold">{item.color}</span>
                        <span className="text-blue-600 font-mono font-bold">{item.position}%</span>
                      </div>
                      <input type="range" min="0" max="100" value={item.position} onChange={(e) => updateColor(index, "position", e.target.value)} className="tool-range" />
                    </div>
                    {colors.length > 2 && (
                      <button onClick={() => setColors(colors.filter((_, current) => current !== index))} className="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-950/20 rounded-xl">
                        <Icons.Trash />
                      </button>
                    )}
                  </div>
                ))}
              </div>

              {colors.length < 5 && (
                <button onClick={addColor} className="w-full py-3 tool-panel-muted rounded-xl font-bold flex items-center justify-center gap-2">
                  <Icons.Plus />
                  {t.add_color}
                </button>
              )}
            </div>
          </div>

          <div className="tool-card rounded-[32px] p-8">
            <div className="text-sm font-bold uppercase tracking-[0.18em] text-slate-400 mb-4">{t.css_code}</div>
            <div className="relative">
              <pre className="p-4 rounded-2xl tool-panel-muted overflow-x-auto"><code className="text-sm font-mono">background: {gradient};</code></pre>
              <button onClick={copyToClipboard} className="absolute top-2 right-2 p-3 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-300 hover:scale-105 transition-transform">
                {copied ? <Icons.Check /> : <Icons.Copy />}
              </button>
            </div>
          </div>
        </div>
      );
    };

    ReactDOM.createRoot(document.getElementById("tool-root")).render(<App />);
    syncHero(shell.getLang());
  </script>
</ToolLayout>
