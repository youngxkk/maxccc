---
import ToolLayout from "../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="PDF 转文字 - DoCool | 本地安全解析"
  description="DoCool PDF 转文字工具，直接在浏览器本地完成 PDF 文字提取，不上传服务器，保护您的隐私。"
  canonical="https://maxc.cc/tools/pdf2text.html"
  icon="📄"
  maxWidthClass="max-w-5xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title" data-i18n="heroTitle">PDF 转文字</h1>
    <p class="tool-subtitle" id="tool-subtitle" data-i18n="heroSubtitle">直接在浏览器中安全提取文档文字。无需上传服务器。</p>
  </header>

  <style is:inline>
    .pdf-tool-container {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .drag-active {
      border-color: #2563eb !important;
      background-color: rgba(37, 99, 235, 0.05) !important;
      transform: scale(1.01);
    }

    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 4px;
    }

    [data-theme='dark'] .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #4b5563;
    }

    .editor-container {
      position: relative;
      height: 500px;
    }

    textarea#output-text {
      width: 100%;
      height: 100%;
      padding: 1.5rem;
      resize: none;
      background: transparent;
      border: none;
      outline: none;
      font-family: inherit;
      line-height: inherit;
      color: inherit;
    }

    .tool-btn-group {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: center;
      margin-top: 1rem;
    }

    .loading-spinner {
      width: 3rem;
      height: 3rem;
      border: 4px solid rgba(148, 163, 184, 0.1);
      border-top-color: #2563eb;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>

  <div class="pdf-tool-container animate-up">
    <!-- Upload Section -->
    <section id="upload-section" class="tool-card rounded-[32px] p-12 text-center cursor-pointer transition-all border-2 border-dashed border-slate-200 dark:border-slate-700 hover:border-blue-500 dark:hover:border-blue-400">
      <input type="file" id="file-input" class="hidden" accept="application/pdf" />
      <div class="space-y-4">
        <div class="mx-auto w-20 h-20 rounded-[24px] bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center text-4xl shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
        </div>
        <div>
          <h3 class="text-2xl font-bold mb-2" data-i18n="dropTitle">点击或拖拽 PDF 到这里</h3>
          <p class="text-slate-500 dark:text-slate-400" data-i18n="dropSubtitle">支持任意大小的 PDF 文档，纯本地处理</p>
        </div>
        <button class="px-8 py-3 bg-blue-600 text-white font-bold rounded-2xl shadow-lg shadow-blue-600/20" data-i18n="selectFileBtn">选择文件</button>
      </div>
    </section>

    <!-- Loading Section -->
    <section id="loading-section" class="hidden tool-card rounded-[32px] p-16 text-center">
      <div class="flex flex-col items-center space-y-6">
        <div class="loading-spinner"></div>
        <div>
          <h3 class="text-2xl font-bold mb-2" data-i18n="processingTitle">正在解析文档...</h3>
          <p id="progress-text" class="text-slate-500 dark:text-slate-400">初始化引擎...</p>
        </div>
      </div>
    </section>

    <!-- Result Section -->
    <section id="result-section" class="hidden flex flex-col space-y-4">
      <div class="tool-card rounded-[32px] overflow-hidden">
        <!-- Toolbar -->
        <div class="p-4 border-b border-slate-100 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 bg-slate-50/50 dark:bg-slate-900/50">
          <div class="flex items-center gap-3 w-full md:w-auto">
            <div class="w-10 h-10 bg-red-100 dark:bg-red-900/30 text-red-500 dark:text-red-400 rounded-lg flex items-center justify-center shrink-0">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div class="min-w-0">
              <h4 id="file-name" class="font-bold truncate max-w-[200px]">document.pdf</h4>
              <span id="page-count" class="text-xs text-slate-500 bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded-full">0 pages</span>
            </div>
          </div>

          <div class="flex flex-wrap gap-2">
            <button id="beautify-btn" class="px-4 py-2 text-sm bg-amber-500 hover:bg-amber-600 text-white rounded-xl shadow-sm transition-all flex items-center gap-2">
              <span>🪄</span> <span data-i18n="btnBeautify">一键美化</span>
            </button>
            <button id="copy-btn" class="px-4 py-2 text-sm tool-panel-muted hover:bg-slate-200 dark:hover:bg-slate-800 rounded-xl transition-all">
              <span>📋</span> <span data-i18n="toastCopied">复制</span>
            </button>
            <button id="download-txt-btn" class="px-4 py-2 text-sm tool-panel-muted hover:bg-slate-200 dark:hover:bg-slate-800 rounded-xl transition-all">
              <span>📄</span> TXT
            </button>
            <button id="download-md-btn" class="px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-xl shadow-md transition-all">
              <span>📝</span> MD
            </button>
            <button id="reset-btn" class="p-2 text-slate-400 hover:text-red-500 transition-all">
              <span>🔄</span>
            </button>
          </div>
        </div>

        <!-- Editor -->
        <div class="editor-container">
          <textarea id="output-text" class="custom-scrollbar" spellcheck="false" placeholder="解析后的内容将显示在这里..."></textarea>
        </div>
      </div>

      <p class="text-center text-slate-400 text-sm">
        <span data-i18n="footerTip">提示：点击“一键美化”可修复 PDF 导致的断行。</span>
      </p>
    </section>
  </div>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script is:inline>
    // PDF.js Worker
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    const translations = {
      "zh-CN": {
        heroTitle: "PDF 转文字",
        heroSubtitle: "直接在浏览器中安全提取文档文字。无需上传服务器。",
        dropTitle: "点击或拖拽 PDF 到此处",
        dropSubtitle: "支持任意大小的 PDF 文档，纯本地处理",
        selectFileBtn: "选择文件",
        processingTitle: "正在解析文档...",
        btnBeautify: "一键美化",
        toastCopied: "复制成功",
        footerTip: "提示：点击“一键美化”可修复 PDF 导致的断行。",
        pagePrefix: "第",
        pageSuffix: "页",
        toastFileError: "请上传 PDF 格式的文件",
        toastSuccess: "解析成功！",
        toastFail: "解析失败，文件可能已加密。",
        toastEmpty: "没有可处理的文字",
        toastFormat: "格式美化完成！",
        pageLabel: "页"
      },
      "zh-TW": {
        heroTitle: "PDF 轉文字",
        heroSubtitle: "直接在瀏覽器中安全地擷取文件文字，無需上傳至伺服器。",
        dropTitle: "點擊或拖曳 PDF 至此處",
        dropSubtitle: "支援任何大小的 PDF 檔案，純本地端處理",
        selectFileBtn: "選取檔案",
        processingTitle: "正在解析文件...",
        btnBeautify: "排版美化",
        toastCopied: "複製成功",
        footerTip: "提示：點擊「排版美化」可修正 PDF 造成的斷行問題。",
        pagePrefix: "第",
        pageSuffix: "頁",
        toastFileError: "請上傳 PDF 格式的檔案",
        toastSuccess: "擷取成功！",
        toastFail: "擷取失敗，檔案可能已加密或損毀。",
        toastEmpty: "沒有可處理的文字內容",
        toastFormat: "格式優化完成！",
        pageLabel: "頁"
      },
      "en": {
        heroTitle: "PDF to Text",
        heroSubtitle: "Securely extract text from your documents directly in your browser. No upload to server.",
        dropTitle: "Click or Drag PDF Here",
        dropSubtitle: "Supports PDFs of any size, 100% client-side",
        selectFileBtn: "Select File",
        processingTitle: "Processing Document...",
        btnBeautify: "Beautify",
        toastCopied: "Copied!",
        footerTip: "Tip: Click \"Beautify\" to fix line breaks from PDF.",
        pagePrefix: "Page",
        pageSuffix: "",
        toastFileError: "Please upload a PDF file.",
        toastSuccess: "Extraction Complete!",
        toastFail: "Extraction Failed. File might be encrypted.",
        toastEmpty: "No text to process",
        toastFormat: "Formatting complete!",
        pageLabel: "Pages"
      }
    };

    const shell = window.ToolShell;
    let currentFileName = 'document';

    const elements = {
      uploadSection: document.getElementById('upload-section'),
      loadingSection: document.getElementById('loading-section'),
      resultSection: document.getElementById('result-section'),
      fileInput: document.getElementById('file-input'),
      outputText: document.getElementById('output-text'),
      fileNameEl: document.getElementById('file-name'),
      pageCountEl: document.getElementById('page-count'),
      progressText: document.getElementById('progress-text'),
      beautifyBtn: document.getElementById('beautify-btn'),
      copyBtn: document.getElementById('copy-btn'),
      downloadTxtBtn: document.getElementById('download-txt-btn'),
      downloadMdBtn: document.getElementById('download-md-btn'),
      resetBtn: document.getElementById('reset-btn')
    };

    function t() {
      const lang = shell.getLang();
      return translations[lang] || translations.en;
    }

    function syncCopy() {
      const copy = t();
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (copy[key]) el.textContent = copy[key];
      });
    }

    async function handleFiles(files) {
      if (!files.length) return;
      const file = files[0];
      const copy = t();

      if (file.type !== 'application/pdf') {
        alert(copy.toastFileError);
        return;
      }

      elements.uploadSection.classList.add('hidden');
      elements.loadingSection.classList.remove('hidden');
      currentFileName = file.name.replace('.pdf', '');
      elements.fileNameEl.textContent = file.name;

      try {
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;
        elements.pageCountEl.textContent = `${pdf.numPages} ${copy.pageLabel}`;

        let fullText = "";
        for (let i = 1; i <= pdf.numPages; i++) {
          elements.progressText.textContent = `${copy.pagePrefix} ${i} / ${pdf.numPages} ${copy.pageSuffix}`;
          const page = await pdf.getPage(i);
          const textContent = await page.getTextContent();
          
          // 修复：确保只处理含有字符串内容的 items
          let pageText = textContent.items
            .filter(item => item.str !== undefined)
            .map(item => item.str)
            .join(' ');
            
          fullText += `--- ${copy.pagePrefix} ${i} ${copy.pageSuffix} ---\n\n${pageText}\n\n\n`;
        }

        elements.outputText.value = fullText;
        elements.loadingSection.classList.add('hidden');
        elements.resultSection.classList.remove('hidden');
      } catch (err) {
        console.error(err);
        alert(copy.toastFail);
        resetApp();
      }
    }

    function resetApp() {
      elements.fileInput.value = '';
      elements.outputText.value = '';
      elements.resultSection.classList.add('hidden');
      elements.loadingSection.classList.add('hidden');
      elements.uploadSection.classList.remove('hidden');
    }

    // Event Listeners
    elements.uploadSection.onclick = () => elements.fileInput.click();
    elements.fileInput.onchange = (e) => handleFiles(e.target.files);

    elements.uploadSection.addEventListener('dragover', (e) => {
      e.preventDefault();
      elements.uploadSection.classList.add('drag-active');
    });

    elements.uploadSection.addEventListener('dragleave', () => {
      elements.uploadSection.classList.remove('drag-active');
    });

    elements.uploadSection.addEventListener('drop', (e) => {
      e.preventDefault();
      elements.uploadSection.classList.remove('drag-active');
      handleFiles(e.dataTransfer.files);
    });

    elements.beautifyBtn.onclick = () => {
      let text = elements.outputText.value;
      if (!text) return;
      const copy = t();
      // Simple regex to fix common PDF line break issues
      // Replace manual page markers with Markdown headers
      const pageRegex = new RegExp(`--- ${copy.pagePrefix} (\\d+) ${copy.pageSuffix} ---`, 'g');
      text = text.replace(pageRegex, '\n## Page $1\n');
      // Fix double newlines
      elements.outputText.value = text.replace(/\n{3,}/g, '\n\n');
      alert(copy.toastFormat);
    };

    elements.copyBtn.onclick = () => {
      elements.outputText.select();
      document.execCommand('copy');
      alert(t().toastCopied);
    };

    elements.downloadTxtBtn.onclick = () => {
      if (!elements.outputText.value) return;
      const blob = new Blob([elements.outputText.value], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${currentFileName}_extracted.txt`;
      a.click();
      URL.revokeObjectURL(url);
    };

    elements.downloadMdBtn.onclick = () => {
      if (!elements.outputText.value) return;
      const blob = new Blob([elements.outputText.value], { type: 'text/markdown' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${currentFileName}_extracted.md`;
      a.click();
      URL.revokeObjectURL(url);
    };

    elements.resetBtn.onclick = resetApp;

    window.addEventListener("tool:langchange", syncCopy);

    // Initial sync
    syncCopy();
  </script>
</ToolLayout>
