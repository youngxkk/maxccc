---
import ToolLayout from "../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="JSON 格式化与校验 - ToolKit.Max | 在线 JSON 格式化工具"
  description="ToolKit.Max JSON 格式化与校验工具，支持 JSON 格式化、压缩、校验、美化。实时语法检查，一键复制，支持深色模式。"
  canonical="https://maxc.cc/tools/json.html"
  icon="📋"
  maxWidthClass="max-w-7xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title">JSON 格式化与校验</h1>
    <p class="tool-subtitle" id="tool-subtitle">在线格式化、校验和美化 JSON 数据</p>
  </header>

  <div id="tool-root" class="animate-up"></div>

  <script type="text/babel" is:inline>
    const { useEffect, useState } = React;
    const shell = window.ToolShell;

    const translations = {
      "zh-CN": {
        title: "JSON 格式化与校验",
        desc: "在线格式化、校验和美化 JSON 数据",
        input_placeholder: "在此粘贴或输入 JSON 数据...",
        format: "格式化",
        minify: "压缩",
        clear: "清空",
        copy: "复制",
        copied: "已复制",
        valid: "JSON 格式正确",
        invalid: "JSON 格式错误",
        input_label: "输入",
        output_label: "输出"
      },
      en: {
        title: "JSON Formatter & Validator",
        desc: "Format, validate and beautify JSON data online",
        input_placeholder: "Paste or type JSON data here...",
        format: "Format",
        minify: "Minify",
        clear: "Clear",
        copy: "Copy",
        copied: "Copied",
        valid: "Valid JSON",
        invalid: "Invalid JSON",
        input_label: "Input",
        output_label: "Output"
      }
    };

    const Icons = {
      Copy: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" /></svg>,
      Check: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
    };

    function syncHero(lang) {
      const t = translations[lang] || translations.en;
      document.getElementById("tool-title").textContent = t.title;
      document.getElementById("tool-subtitle").textContent = t.desc;
    }

    const App = () => {
      const [lang, setLang] = useState(shell.getLang());
      const [input, setInput] = useState("");
      const [output, setOutput] = useState("");
      const [error, setError] = useState("");
      const [valid, setValid] = useState(null);
      const [copied, setCopied] = useState(false);
      const t = translations[lang] || translations.en;

      useEffect(() => syncHero(lang), [lang]);
      useEffect(() => shell.subscribeLang(setLang), []);

      const runFormat = (minify = false) => {
        if (!input.trim()) {
          setOutput("");
          setError("");
          setValid(null);
          return;
        }
        try {
          const parsed = JSON.parse(input);
          setOutput(minify ? JSON.stringify(parsed) : JSON.stringify(parsed, null, 2));
          setError("");
          setValid(true);
        } catch (currentError) {
          setOutput("");
          setError(currentError.message);
          setValid(false);
        }
      };

      const clearAll = () => {
        setInput("");
        setOutput("");
        setError("");
        setValid(null);
      };

      const copyOutput = async () => {
        if (!output) return;
        await navigator.clipboard.writeText(output);
        setCopied(true);
        setTimeout(() => setCopied(false), 2000);
      };

      return (
        <div className="space-y-6">
          <div className={`tool-card rounded-[28px] p-4 flex items-start gap-3 ${valid === true ? "border-green-300" : valid === false ? "border-red-300" : ""}`}>
            {valid === true && <span className="font-semibold text-green-600">{t.valid}</span>}
            {valid === false && <div className="flex-1"><div className="font-semibold text-red-600 mb-1">{t.invalid}</div><div className="text-sm text-red-500 break-words">{error}</div></div>}
            {valid === null && <span className="text-sm text-slate-400">Status</span>}
          </div>

          <div className="flex flex-wrap gap-3">
            <button onClick={() => runFormat(false)} disabled={!input.trim()} className="flex-1 min-w-[120px] py-3 px-6 bg-blue-600 disabled:bg-slate-300 text-white font-bold rounded-xl shadow-lg disabled:shadow-none">{t.format}</button>
            <button onClick={() => runFormat(true)} disabled={!input.trim()} className="flex-1 min-w-[120px] py-3 px-6 bg-fuchsia-600 disabled:bg-slate-300 text-white font-bold rounded-xl shadow-lg disabled:shadow-none">{t.minify}</button>
            <button onClick={copyOutput} disabled={!output} className="py-3 px-6 tool-panel-muted font-bold rounded-xl disabled:opacity-50 flex items-center gap-2">{copied ? <Icons.Check /> : <Icons.Copy />}{copied ? t.copied : t.copy}</button>
            <button onClick={clearAll} className="py-3 px-6 tool-panel-muted font-bold rounded-xl">{t.clear}</button>
          </div>

          <div className="grid md:grid-cols-2 gap-6">
            <div className="tool-card rounded-[32px] p-6">
              <div className="text-sm font-bold uppercase tracking-[0.18em] text-slate-400 mb-4">{t.input_label}</div>
              <textarea value={input} onChange={(e) => setInput(e.target.value)} placeholder={t.input_placeholder} className="w-full h-[500px] p-4 rounded-2xl tool-panel-muted focus:outline-none focus:ring-2 focus:ring-blue-500/50 text-sm font-mono" spellCheck="false"></textarea>
            </div>
            <div className="tool-card rounded-[32px] p-6">
              <div className="text-sm font-bold uppercase tracking-[0.18em] text-slate-400 mb-4">{t.output_label}</div>
              <div className="w-full h-[500px] p-4 rounded-2xl tool-panel-muted overflow-auto">
                <pre className="text-sm whitespace-pre-wrap break-words font-mono">{output || " "}</pre>
              </div>
            </div>
          </div>
        </div>
      );
    };

    ReactDOM.createRoot(document.getElementById("tool-root")).render(<App />);
    syncHero(shell.getLang());
  </script>
</ToolLayout>
