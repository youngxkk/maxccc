---
import ToolLayout from "../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="BMI计算器 - ToolKit.Max | 快速测量您的身体质量指数"
  description="ToolKit.Max BMI计算器，帮助您快速测量身体质量指数（BMI），并了解您的健康状况。简单直观，保护隐私。"
  canonical="https://maxc.cc/tools/bmi.html"
  icon="🏃"
  maxWidthClass="max-w-3xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title">BMI 计算器</h1>
    <p class="tool-subtitle" id="tool-subtitle">关注您的身体质量指数与健康</p>
  </header>

  <div id="tool-root" class="animate-up"></div>

  <script type="text/babel" is:inline>
    const { useEffect, useState } = React;
    const shell = window.ToolShell;

    const translations = {
      "zh-CN": {
        title: "BMI 计算器",
        desc: "关注您的身体质量指数与健康",
        height: "身高",
        weight: "体重",
        status_thin: "偏瘦",
        status_normal: "正常",
        status_overweight: "超重",
        status_obese: "肥胖"
      },
      en: {
        title: "BMI Calculator",
        desc: "Track your Body Mass Index & Health",
        height: "Height",
        weight: "Weight",
        status_thin: "Underweight",
        status_normal: "Normal",
        status_overweight: "Overweight",
        status_obese: "Obese"
      }
    };

    function syncHero(lang) {
      const t = translations[lang] || translations.en;
      document.getElementById("tool-title").textContent = t.title;
      document.getElementById("tool-subtitle").textContent = t.desc;
    }

    const App = () => {
      const [lang, setLang] = useState(shell.getLang());
      const [height, setHeight] = useState(175);
      const [weight, setWeight] = useState(70);
      const t = translations[lang] || translations.en;

      useEffect(() => syncHero(lang), [lang]);
      useEffect(() => shell.subscribeLang(setLang), []);

      const bmi = (weight / ((height / 100) ** 2)).toFixed(1);
      let status = t.status_normal;
      let badge = "bg-green-500";
      let color = "text-green-600";
      if (bmi < 18.5) { status = t.status_thin; badge = "bg-yellow-500"; color = "text-yellow-600"; }
      else if (bmi >= 24 && bmi < 28) { status = t.status_overweight; badge = "bg-orange-500"; color = "text-orange-600"; }
      else if (bmi >= 28) { status = t.status_obese; badge = "bg-red-500"; color = "text-red-600"; }

      return (
        <div className="tool-card rounded-[32px] p-8 md:p-10">
          <div className="grid md:grid-cols-[1.2fr_1fr] gap-8 items-center">
            <div className="space-y-10">
              <div className="space-y-4">
                <div className="flex justify-between font-bold">
                  <span>{t.height}</span>
                  <span className="text-blue-600 text-xl font-mono">{height} cm</span>
                </div>
                <input type="range" min="100" max="220" value={height} onChange={(e) => setHeight(Number(e.target.value))} className="tool-range" />
              </div>

              <div className="space-y-4">
                <div className="flex justify-between font-bold">
                  <span>{t.weight}</span>
                  <span className="text-blue-600 text-xl font-mono">{weight} kg</span>
                </div>
                <input type="range" min="30" max="150" value={weight} onChange={(e) => setWeight(Number(e.target.value))} className="tool-range" />
              </div>
            </div>

            <div className="tool-panel-muted rounded-[30px] p-8 text-center shadow-inner">
              <div className="text-sm font-bold uppercase tracking-[0.18em] text-slate-400 mb-2">BMI</div>
              <div className={`text-6xl font-black tracking-tighter mb-4 ${color}`}>{bmi}</div>
              <div className={`inline-flex px-4 py-1.5 rounded-full text-white text-sm font-bold shadow-lg ${badge}`}>{status}</div>
            </div>
          </div>
        </div>
      );
    };

    ReactDOM.createRoot(document.getElementById("tool-root")).render(<App />);
    syncHero(shell.getLang());
  </script>
</ToolLayout>
