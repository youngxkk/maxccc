---
import ToolLayout from "../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="密码生成器 - ToolKit.Max | 高强度随机密码生成"
  description="ToolKit.Max 密码生成器，提供安全、高强度的随机密码生成服务。支持自定义长度、数字、符号和大写字母。所有操作均在本地完成，确保隐私安全。"
  canonical="https://maxc.cc/tools/password.html"
  icon="🔑"
  maxWidthClass="max-w-3xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title">密码生成器</h1>
    <p class="tool-subtitle" id="tool-subtitle">生成安全、强大的随机密码</p>
  </header>

  <div id="tool-root" class="animate-up"></div>

  <script type="text/babel" is:inline>
    const { useEffect, useState } = React;
    const shell = window.ToolShell;

    const translations = {
      "zh-CN": {
        title: "密码生成器",
        desc: "生成安全、强大的随机密码",
        length: "长度",
        numbers: "数字",
        symbols: "符号",
        uppercase: "大写字母",
        generate: "重新生成",
        copied: "已复制",
        privacy: "您的隐私很重要：所有密码均在您的设备上本地生成，永远不会发送到服务器。"
      },
      en: {
        title: "Password Generator",
        desc: "Generate secure and powerful random passwords",
        length: "Length",
        numbers: "Numbers",
        symbols: "Symbols",
        uppercase: "Uppercase",
        generate: "Regenerate",
        copied: "Copied",
        privacy: "Your privacy matters: all passwords are generated locally on your device and never sent to a server."
      }
    };

    const Icons = {
      Copy: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" /></svg>,
      Check: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
    };

    function syncHero(lang) {
      const t = translations[lang] || translations.en;
      document.getElementById("tool-title").textContent = t.title;
      document.getElementById("tool-subtitle").textContent = t.desc;
    }

    const App = () => {
      const [lang, setLang] = useState(shell.getLang());
      const [length, setLength] = useState(12);
      const [options, setOptions] = useState({ numbers: true, symbols: true, uppercase: true });
      const [password, setPassword] = useState("");
      const [copied, setCopied] = useState(false);

      const t = translations[lang] || translations.en;

      useEffect(() => {
        syncHero(lang);
      }, [lang]);

      useEffect(() => shell.subscribeLang(setLang), []);

      const generate = () => {
        const chars = {
          lower: "abcdefghijklmnopqrstuvwxyz",
          upper: "ABCDEFGHIJKLMNOPQRSTUVWXYZ",
          num: "0123456789",
          sym: "!@#$%^&*()_+-=[]{}|;:,.<>?"
        };
        let value = chars.lower;
        if (options.uppercase) value += chars.upper;
        if (options.numbers) value += chars.num;
        if (options.symbols) value += chars.sym;

        let result = "";
        for (let i = 0; i < length; i += 1) {
          result += value.charAt(Math.floor(Math.random() * value.length));
        }
        setPassword(result);
      };

      useEffect(() => {
        generate();
      }, [length, options]);

      const copyToClipboard = async () => {
        await navigator.clipboard.writeText(password);
        setCopied(true);
        setTimeout(() => setCopied(false), 2000);
      };

      return (
        <div className="tool-card rounded-[32px] p-8 md:p-10">
          <div className="tool-panel-muted rounded-[26px] min-h-[120px] mb-8 flex items-center justify-center px-4 relative">
            <span className="text-2xl md:text-3xl font-mono text-blue-600 break-all text-center">{password}</span>
            <button onClick={copyToClipboard} className="absolute top-3 right-3 p-3 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-300 hover:scale-105 transition-transform">
              {copied ? <Icons.Check /> : <Icons.Copy />}
            </button>
            {copied && <span className="absolute bottom-3 right-4 text-xs font-bold text-green-500">{t.copied}</span>}
          </div>

          <div className="space-y-8">
            <div className="space-y-4">
              <div className="flex justify-between items-center font-bold">
                <span>{t.length}</span>
                <span className="text-blue-600 text-xl font-mono">{length}</span>
              </div>
              <input type="range" min="6" max="64" value={length} onChange={(e) => setLength(parseInt(e.target.value, 10))} className="tool-range" />
            </div>

            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              {Object.keys(options).map((key) => (
                <label key={key} className="flex items-center justify-between p-4 rounded-2xl tool-panel-muted cursor-pointer">
                  <span className="font-medium">{t[key]}</span>
                  <input type="checkbox" checked={options[key]} onChange={() => setOptions({ ...options, [key]: !options[key] })} className="h-5 w-5 accent-blue-600 rounded" />
                </label>
              ))}
            </div>

            <button onClick={generate} className="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl shadow-lg shadow-blue-600/20 transition-colors">
              {t.generate}
            </button>
          </div>

          <div className="mt-10 text-center text-sm text-slate-400 leading-relaxed italic">
            {t.privacy}
          </div>
        </div>
      );
    };

    ReactDOM.createRoot(document.getElementById("tool-root")).render(<App />);
    syncHero(shell.getLang());
  </script>
</ToolLayout>
