---
import ToolLayout from "../../layouts/ToolLayout.astro";
---

<ToolLayout
  title="随机文本生成器 - ToolKit.Max | 占位文本与测试数据"
  description="ToolKit.Max 随机文本生成器，提供随机段落、姓名、邮箱等测试数据生成服务。极简设计，即开即用，适合设计师和开发者快速填充内容。"
  canonical="https://maxc.cc/tools/lorem.html"
  icon="📝"
  maxWidthClass="max-w-3xl"
>
  <header class="tool-hero animate-up">
    <h1 class="tool-title" id="tool-title">随机文本生成器</h1>
    <p class="tool-subtitle" id="tool-subtitle">占位文本与测试数据专家</p>
  </header>

  <div id="tool-root" class="animate-up"></div>

  <script type="text/babel" is:inline>
    const { useEffect, useState } = React;
    const shell = window.ToolShell;

    const translations = {
      "zh-CN": {
        title: "随机文本生成器",
        desc: "占位文本与测试数据专家",
        type_paragraph: "随机段落",
        type_name: "随机姓名",
        type_email: "随机邮箱",
        generate: "立即生成",
        copied: "已复制"
      },
      en: {
        title: "Lorem Ipsum Generator",
        desc: "Placeholder text & test data expert",
        type_paragraph: "Paragraph",
        type_name: "Random Name",
        type_email: "Random Email",
        generate: "Generate Now",
        copied: "Copied"
      }
    };

    const Icons = {
      Copy: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" /></svg>,
      Check: () => <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
    };

    const data = {
      paragraph: [
        "设计不仅是外观，更是产品如何运作。",
        "极简主义不是去除多余，而是专注于核心。",
        "好的工具应当像空气一样，需要时无处不在，平时不留痕迹。",
        "Design is not just what it looks like and feels like. Design is how it works."
      ],
      name: ["张晓明", "李华", "王志强", "陈静", "James Smith", "Emma Wilson"],
      email: ["contact@toolkit.max", "hello@example.com", "support@app.com", "dev@studio.net"]
    };

    function syncHero(lang) {
      const t = translations[lang] || translations.en;
      document.getElementById("tool-title").textContent = t.title;
      document.getElementById("tool-subtitle").textContent = t.desc;
    }

    const App = () => {
      const [lang, setLang] = useState(shell.getLang());
      const [type, setType] = useState("paragraph");
      const [result, setResult] = useState("");
      const [copied, setCopied] = useState(false);
      const t = translations[lang] || translations.en;

      useEffect(() => syncHero(lang), [lang]);
      useEffect(() => shell.subscribeLang(setLang), []);
      useEffect(() => generate(), [type]);

      const generate = () => {
        const list = data[type];
        setResult(list[Math.floor(Math.random() * list.length)]);
      };

      const copyToClipboard = async () => {
        await navigator.clipboard.writeText(result);
        setCopied(true);
        setTimeout(() => setCopied(false), 2000);
      };

      return (
        <div className="tool-card rounded-[32px] p-8 md:p-10">
          <div className="space-y-6">
            <div className="relative">
              <select value={type} onChange={(e) => setType(e.target.value)} className="w-full p-4 rounded-2xl tool-panel-muted font-bold focus:outline-none focus:ring-2 focus:ring-blue-500/50 appearance-none">
                <option value="paragraph">{t.type_paragraph}</option>
                <option value="name">{t.type_name}</option>
                <option value="email">{t.type_email}</option>
              </select>
              <div className="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">⌄</div>
            </div>

            <div className="p-6 tool-panel-muted rounded-[26px] min-h-[150px] flex items-center justify-center relative">
              <p className="text-lg text-center leading-relaxed italic">{result}</p>
              <button onClick={copyToClipboard} className="absolute bottom-3 right-3 p-3 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-300 hover:scale-105 transition-transform">
                {copied ? <Icons.Check /> : <Icons.Copy />}
              </button>
            </div>

            <button onClick={generate} className="w-full py-4 bg-slate-900 dark:bg-blue-600 text-white font-bold rounded-2xl shadow-lg transition-colors">
              {t.generate}
            </button>
          </div>
        </div>
      );
    };

    ReactDOM.createRoot(document.getElementById("tool-root")).render(<App />);
    syncHero(shell.getLang());
  </script>
</ToolLayout>
