---
import MainNav from "../components/MainNav.astro";
import ToolFooter from "../components/ToolFooter.astro";
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  description: string;
  canonical: string;
  icon: string;
  lang?: string;
  maxWidthClass?: string;
  extraStyles?: string;
};

const {
  title,
  description,
  canonical,
  icon,
  lang = "zh-CN",
  maxWidthClass = "max-w-3xl",
  extraStyles = ""
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang={lang}
  includeFirebaseAuth={true}
>
  <Fragment slot="head">
    <link rel="icon" href={`data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>${icon}</text></svg>`} />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        darkMode: ['selector', '[data-theme="dark"]'],
        theme: {
          extend: {
            fontFamily: {
              sans: ['Outfit', 'Inter', 'sans-serif'],
            },
          }
        }
      };
    </script>
    <script is:inline src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin="anonymous"></script>
    <script is:inline src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin="anonymous"></script>
    <script is:inline src="https://unpkg.com/@babel/standalone/babel.min.js" crossorigin="anonymous"></script>
    <style is:inline>
      @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

      :root {
        --tool-bg: #f8fafc;
        --tool-text: #0f172a;
        --tool-card: rgba(255, 255, 255, 0.92);
        --tool-nav: rgba(255, 255, 255, 0.8);
        --tool-border: rgba(15, 23, 42, 0.08);
        --tool-muted: #64748b;
        --tool-accent: #2563eb;
      }

      [data-theme='dark'] {
        --tool-bg: #020617;
        --tool-text: #f1f5f9;
        --tool-card: rgba(30, 41, 59, 0.92);
        --tool-nav: rgba(15, 23, 42, 0.8);
        --tool-border: rgba(255, 255, 255, 0.1);
        --tool-muted: #94a3b8;
        --tool-accent: #60a5fa;
      }

      body {
        font-family: 'Outfit', -apple-system, sans-serif;
        background:
          radial-gradient(circle at top, rgba(37, 99, 235, 0.12), transparent 38%),
          var(--tool-bg);
        color: var(--tool-text);
        min-height: 100vh;
        transition: background-color 0.3s ease, color 0.3s ease;
      }

      a {
        text-decoration: none;
        color: inherit;
        -webkit-tap-highlight-color: transparent;
      }

      nav {
        position: sticky;
        top: 0;
        left: 0;
        width: 100%;
        height: 48px;
        background: var(--tool-nav);
        backdrop-filter: saturate(180%) blur(20px);
        -webkit-backdrop-filter: saturate(180%) blur(20px);
        z-index: 9999;
        display: flex;
        justify-content: center;
        border-bottom: 1px solid var(--tool-border);
      }

      .nav-content {
        max-width: 1100px;
        width: 100%;
        padding: 0 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 100%;
      }

      .nav-left {
        display: flex;
        align-items: center;
        gap: 40px;
      }

      .nav-logo {
        font-size: 19px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 4px;
        opacity: 0.9;
        transition: opacity 0.2s ease;
      }

      .nav-logo:hover {
        opacity: 1;
      }

      .nav-links {
        display: flex;
        gap: 24px;
      }

      .nav-links a {
        font-size: 13px;
        font-weight: 500;
        color: var(--tool-muted);
        transition: color 0.2s ease;
      }

      .nav-links a:hover {
        color: var(--tool-text);
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .lang-selector {
        position: relative;
      }

      .lang-btn,
      .theme-toggle {
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--tool-text);
        padding: 8px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.82;
        transition: opacity 0.2s ease, background-color 0.2s ease;
      }

      .lang-btn:hover,
      .theme-toggle:hover {
        opacity: 1;
        background: rgba(148, 163, 184, 0.12);
      }

      .lang-btn svg,
      .theme-toggle svg {
        width: 20px;
        height: 20px;
      }

      .lang-dropdown {
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 8px;
        background: var(--tool-card);
        backdrop-filter: saturate(180%) blur(20px);
        -webkit-backdrop-filter: saturate(180%) blur(20px);
        border: 1px solid var(--tool-border);
        border-radius: 14px;
        padding: 8px;
        min-width: 140px;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.14);
        display: none;
        flex-direction: column;
        z-index: 10000;
      }

      .lang-dropdown.show {
        display: flex;
      }

      .lang-dropdown button {
        background: transparent;
        border: none;
        padding: 8px 12px;
        text-align: left;
        color: var(--tool-text);
        font-size: 13px;
        border-radius: 8px;
        cursor: pointer;
        transition: background-color 0.2s ease;
      }

      .lang-dropdown button:hover {
        background: rgba(148, 163, 184, 0.12);
      }

      .tool-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .tool-main {
        flex: 1;
        width: 100%;
        margin: 0 auto;
        padding: 3.5rem 1.5rem 5rem;
      }

      .tool-hero {
        text-align: center;
        margin-bottom: 2.5rem;
      }

      .tool-title {
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        line-height: 1.05;
        font-weight: 700;
        letter-spacing: -0.04em;
        margin-bottom: 1rem;
      }

      .tool-subtitle {
        color: var(--tool-muted);
        font-size: 1.1rem;
      }

      .tool-card {
        background: var(--tool-card);
        border: 1px solid var(--tool-border);
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        backdrop-filter: blur(24px) saturate(160%);
        -webkit-backdrop-filter: blur(24px) saturate(160%);
      }

      [data-theme='dark'] .tool-card {
        box-shadow: 0 24px 60px rgba(2, 6, 23, 0.45);
      }

      .tool-panel-muted {
        background: rgba(148, 163, 184, 0.08);
        border: 1px solid rgba(148, 163, 184, 0.14);
      }

      [data-theme='dark'] .tool-panel-muted {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(255, 255, 255, 0.08);
      }

      .tool-footer {
        margin-top: auto;
        padding: 0 1.5rem 2rem;
      }

      .tool-footer-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1.5rem;
        border-radius: 32px;
        background: var(--tool-card);
        border: 1px solid var(--tool-border);
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        backdrop-filter: blur(24px) saturate(160%);
        -webkit-backdrop-filter: blur(24px) saturate(160%);
      }

      .tool-footer-title {
        margin-bottom: 1.2rem;
        text-align: center;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--tool-muted);
      }

      .tool-footer-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
        gap: 0.9rem;
      }

      .tool-footer-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.45rem;
        padding: 1rem 0.6rem;
        border-radius: 20px;
        transition: background-color 0.2s ease, transform 0.2s ease;
      }

      .tool-footer-link:hover {
        background: rgba(148, 163, 184, 0.12);
        transform: translateY(-2px);
      }

      .tool-footer-icon {
        font-size: 1.7rem;
      }

      .tool-footer-label {
        font-size: 0.75rem;
        font-weight: 600;
        text-align: center;
        color: var(--tool-muted);
      }

      .tool-footer-legal,
      .tool-footer-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        justify-content: center;
        margin-top: 1.4rem;
        color: var(--tool-muted);
        font-size: 0.78rem;
      }

      .tool-footer-meta {
        justify-content: space-between;
        align-items: center;
      }

      .tool-footer-meta-links {
        display: flex;
        gap: 1rem;
      }

      .tool-footer a {
        color: inherit;
        text-decoration: none;
      }

      .tool-footer a:hover {
        color: var(--tool-text);
      }

      .tool-range {
        width: 100%;
        height: 0.5rem;
        cursor: pointer;
        appearance: none;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.22);
      }

      .tool-range::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 18px;
        height: 18px;
        border-radius: 999px;
        background: var(--tool-accent);
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.35);
      }

      input[type="color"] {
        -webkit-appearance: none;
        appearance: none;
        width: 52px;
        height: 52px;
        background: transparent;
        border: 0;
        cursor: pointer;
      }

      input[type="color"]::-webkit-color-swatch {
        border-radius: 14px;
        border: 2px solid rgba(15, 23, 42, 0.08);
      }

      [data-theme='dark'] input[type="color"]::-webkit-color-swatch {
        border-color: rgba(255, 255, 255, 0.12);
      }

      textarea {
        resize: none;
      }

      .animate-up {
        animation: fadeInUp 0.5s ease-out forwards;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 768px) {
        .nav-content {
          padding: 0 14px;
        }

        .nav-left {
          gap: 12px;
        }

        .nav-logo {
          font-size: 17px;
        }

        .nav-links {
          display: none;
        }

        .tool-main {
          padding: 2.5rem 1rem 4rem;
        }

        .tool-footer {
          padding: 0 1rem 1rem;
        }

        .tool-footer-meta {
          justify-content: center;
        }
      }
      ${extraStyles}
    </style>
  </Fragment>

  <div class="tool-page">
    <MainNav showSectionLinks={false} />
    <main class:list={["tool-main", maxWidthClass]}>
      <slot />
    </main>
    <ToolFooter />
  </div>

  <script is:inline src="/tool-shell.js"></script>
</BaseLayout>
